---
const { href, name, membersCount } = Astro.props;
---

<a href={href} class="org-card glass-panel">
    <div class="card-top">
        <div class="logo-container">
            <slot />
        </div>
        <h3>{name}</h3>
        <span class="badge badge-count"
            >{membersCount}
            {membersCount === 1 ? "Diputado" : "Diputados"}</span
        >
    </div>
</a>

<style>
    .org-card {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        padding: 1.75rem;
    }

    .card-top {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0.75rem;
    }

    .logo-container {
        width: 120px;
        height: 120px;
        display: flex;
        place-items: center;
        justify-content: center;
    }

    .org-card h3 {
        font-size: 1.25rem;
        color: var(--accent-color);
        line-height: 1.3;
        margin: 0;
    }

    .badge-count {
        background: rgba(88, 166, 255, 0.15);
        color: var(--accent-color);
        border-color: rgba(88, 166, 255, 0.3);
        font-size: 0.85rem;
        padding: 0.3rem 0.85rem;
    }

    /* Metrics rows */
    .metrics {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
        border-top: 1px solid var(--border-color);
        padding-top: 1rem;
    }

    .metric-row {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .metric-label {
        font-size: 0.72rem;
        color: var(--text-muted);
        font-weight: 600;
        min-width: 73px;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .metric-bar-bg {
        flex: 1;
        height: 7px;
        border-radius: 4px;
        background: var(--bg-tertiary);
        overflow: hidden;
    }

    .metric-bar-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.4s ease;
    }

    .metric-value {
        font-size: 0.75rem;
        font-weight: 700;
        min-width: 36px;
        text-align: right;
    }

    .org-card:hover {
        border-color: var(--accent-color);
        transform: translateY(-2px);
    }
</style>
