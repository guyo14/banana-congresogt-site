---
interface Props {
  labels: string[];
  data: number[];
  title?: string;
}

const { labels, data, title } = Astro.props;

// Generate unique IDs so multiple charts coexist cleanly
const uniqueId = Math.random().toString(36).substring(2, 9);
const chartId = `donutChart-${uniqueId}`;
const legendId = `donutLegend-${uniqueId}`;
---

<div class="donut-component banana-chart-container">
  <!-- Data payload for scripts/chart-processing.ts -->
  <span
    class="banana-chart-data"
    style="display:none;"
    data-type="donut"
    data-chart={chartId}
    data-legend={legendId}
    data-labels={JSON.stringify(labels)}
    data-data={JSON.stringify(data)}></span>

  {
    title && (
      <h3 class="sub-title">
        {title}
      </h3>
    )
  }

  <div class="donut-container">
    <div class="chart-box donut-box">
      <canvas id={chartId}></canvas>
    </div>
    <div class="legend-side">
      <div id={legendId} class="donut-legend-wrap"></div>
    </div>
  </div>
</div>

<style>
  .donut-component {
    width: 100%;
    margin-bottom: 2rem;
  }
  .donut-container {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    align-items: center;
  }
  .donut-box {
    flex-shrink: 0;
    width: 250px;
    height: 250px;
    max-width: 100%;
  }
</style>

<script src="../scripts/chart-processing.ts"></script>
