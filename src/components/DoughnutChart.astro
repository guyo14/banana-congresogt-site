---
interface Props {
  labels: string[];
  data: number[];
  title?: string;
}

const { labels, data, title } = Astro.props;

// Generate unique IDs so multiple charts coexist cleanly
const uniqueId = Math.random().toString(36).substring(2, 9);
const chartId = `donutChart-${uniqueId}`;
const legendId = `donutLegend-${uniqueId}`;
---

<div class="donut-component banana-chart-container">
  <!-- Data payload for scripts/chart-processing.ts -->
  <span
    class="banana-chart-data"
    style="display:none;"
    data-type="donut"
    data-chart={chartId}
    data-legend={legendId}
    data-labels={JSON.stringify(labels)}
    data-data={JSON.stringify(data)}></span>

  {
    title && (
      <h3 class="sub-title">
        {title}
      </h3>
    )
  }

  <div class="donut-container">
    <div class="chart-box donut-box">
      <canvas id={chartId}></canvas>
    </div>
    <div class="legend-side">
      <div id={legendId} class="donut-legend-wrap"></div>
    </div>
  </div>
</div>

<style>
  .donut-component {
    width: 100%;
    margin-bottom: 2rem;
  }
  .sub-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .chart-box {
    position: relative;
    height: 250px;
    width: 100%;
    margin: 0 auto;
    min-width: 0;
  }
  .donut-container {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    align-items: center;
  }
  .donut-box {
    flex-shrink: 0;
    width: 250px;
    height: 250px;
    max-width: 100%;
  }
  .legend-side {
    flex: 1;
    min-width: 240px;
    width: 100%;
    max-width: 450px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

</style>

<script src="../scripts/chart-processing.ts"></script>
