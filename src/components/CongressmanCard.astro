---
import {getCongressmanPath, getCongressmanPhotoPath} from "../lib/paths.ts";
import {CONGRESSMAN_STATUS} from "../lib/mappers.ts";
interface Props {
  id: number;
  firstName: string;
  lastName: string;
  status: number;
  blockId: number;
  blockName: string;
  districtId: number;
  districtName: string;
}

const {
  id,
  firstName,
  lastName,
  status,
  blockId,
  blockName,
  districtId,
  districtName
} = Astro.props;

const fullName = `${firstName} ${lastName}`;
---

<a
        href={getCongressmanPath(id)}
        class="congressman-card glass-panel"
        data-name={fullName.toLowerCase()}
        data-block={status == CONGRESSMAN_STATUS.ACTIVE ? blockId : -2}
        data-district={districtId}
        data-status={status}
>
    <div class="card-image">
        <img src={getCongressmanPhotoPath(id)} alt={fullName} loading="lazy" />
    </div>
    <div class="card-info">
        <h3>{firstName}<br/>{lastName}</h3>
        <div class="tags">
            {status === CONGRESSMAN_STATUS.INACTIVE ?
              <span class="badge badge-inactive">Inactivo</span>:
              blockName && <span class="badge badge-accent">{blockName}</span>}
            <span class="badge badge-district">{districtName}</span>
        </div>
    </div>
</a>

<style>
    .congressman-card {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        color: inherit;
        align-items: center;
        text-align: center;
        transition: transform var(--transition-fast), border-color var(--transition-fast);
    }
    .congressman-card:hover {
        border-color: var(--accent-color);
        transform: translateY(-2px);
    }

    .card-image {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        overflow: hidden;
        background: var(--bg-tertiary);
        border: 3px solid var(--border-color);
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .placeholder-img {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
    }

    .card-info {
        width: 100%;
    }

    .card-info h3 {
        margin-bottom: 0.75rem;
        font-size: 1.1rem;
    }

    .tags {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 0.75rem;
    }

    .badge-inactive {
        background: color-mix(in srgb, var(--color-contra) 16%, white);
        color: color-mix(in srgb, var(--color-contra) 78%, #5b1320);
        border-color: color-mix(in srgb, var(--color-contra) 38%, white);
    }

    .badge-district {
        background: rgba(139, 148, 158, 0.15);
        border-color: rgba(139, 148, 158, 0.3);
    }
</style>
