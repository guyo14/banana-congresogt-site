---
const {
  id,
  fullName,
  firstName,
  lastName,
  blockId,
  blockName,
  districtId,
  districtName,
  attendancePercent
} = Astro.props;

const color = attendancePercent >= 80 ? 'var(--color-acceptable)' : attendancePercent >= 50 ? 'var(--color-borderline)' : 'var(--color-unacceptable)';
---

<a
        href={`/congresistas/${id}`}
        class="congressman-card glass-panel"
        data-name={fullName.toLowerCase()}
        data-block={blockId}
        data-district={districtId}
        data-attendance={attendancePercent}
>
    <div class="card-image">
        <img src={`/congressmen/${id}.jpg`} alt={fullName} loading="lazy" />
    </div>
    <div class="card-info">
        <h3>{firstName}<br/>{lastName}</h3>
        <div class="tags">
            <span class="badge badge-party">{blockName}</span>
            <span class="badge badge-district">{districtName}</span>
        </div>
        <div class="att-bar-wrapper" title={`Asistencia: ${attendancePercent}%`}>
            <div class="att-bar-bg">
                <div class="att-bar-fill" style={`width: ${attendancePercent}%; background: ${color};`}></div>
            </div>
            <span class="att-label" style={`color: ${color};`}>{attendancePercent}%</span>
        </div>
    </div>
</a>

<style>
    .congressman-card {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        color: inherit;
        align-items: center;
        text-align: center;
    }

    .card-image {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        overflow: hidden;
        background: var(--bg-tertiary);
        border: 3px solid var(--border-color);
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .placeholder-img {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
    }

    .card-info {
        width: 100%;
    }

    .card-info h3 {
        margin-bottom: 0.75rem;
        font-size: 1.1rem;
    }

    .tags {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 0.75rem;
    }

    .badge-party {
        background: rgba(88, 166, 255, 0.15);
        color: var(--accent-color);
        border-color: rgba(88, 166, 255, 0.3);
    }

    .badge-district {
        background: rgba(139, 148, 158, 0.15);
        border-color: rgba(139, 148, 158, 0.3);
    }

    /* Attendance mini-bar */
    .att-bar-wrapper {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.25rem;
        padding: 0 0.25rem;
    }

    .att-bar-bg {
        flex: 1;
        height: 6px;
        border-radius: 3px;
        background: var(--bg-tertiary);
        overflow: hidden;
    }

    .att-bar-fill {
        height: 100%;
        border-radius: 3px;
        transition: width 0.3s ease;
    }

    .att-label {
        font-size: 0.75rem;
        font-weight: 700;
        min-width: 36px;
        text-align: right;
    }

    @media (max-width: 768px) {
        .card-image {
            width: 80px;
            height: 80px;
        }
        .card-info h3 {
            font-size: 0.95rem;
        }
        .congressman-card {
            padding: 1rem 0.75rem;
            gap: 0.75rem;
        }
    }
</style>