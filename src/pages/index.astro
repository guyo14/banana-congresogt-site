---
import Layout from '../layouts/Layout.astro';
import db from '../lib/db.ts';
import type { NoParams, CountQuery } from '../lib/types.ts';
import {BLOCKS_PATH, CONGRESSMEN_PATH, DISTRICT_PATH, PARTIES_PATH, SESSIONS_PATH, VOTES_PATH} from "../lib/paths.ts";
import {CONGRESSMAN_STATUS} from "../lib/mappers.ts";

// Get high-level metrics for the landing page
const stats = {
  congressmen: db.prepare<number, CountQuery>(`SELECT COUNT(*) as count FROM congressmen WHERE status = ?`).get(CONGRESSMAN_STATUS.ACTIVE)?.count,
  blocks: db.prepare<NoParams, CountQuery>('SELECT COUNT(*) as count FROM blocks').get()?.count,
  parties: db.prepare<NoParams, CountQuery>('SELECT COUNT(*) as count FROM parties').get()?.count,
  districts: db.prepare<NoParams, CountQuery>('SELECT COUNT(*) as count FROM districts').get()?.count,
  sessions: db.prepare<NoParams, CountQuery>('SELECT COUNT(*) as count FROM sessions').get()?.count,
  voting: db.prepare<NoParams, CountQuery>('SELECT COUNT(*) as count FROM voting').get()?.count,
};

// Derive the "data freshness" date from the most recent sessions
const lastSession = db.prepare<NoParams, { date: string }>(`
  SELECT start_date AS date
  FROM sessions
  ORDER BY start_date DESC
  LIMIT 1
`).get();
const lastUpdateDate = lastSession
  ? new Date(lastSession.date).toLocaleDateString('es-GT', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---

<Layout title="Inicio">
  <div class="hero-section text-center">
    <h1 class="hero-title">Audita a tu Congreso</h1>
    <h2 class="hero-subtitle">X Legislatura · 2024&ndash;2027</h2>
    {lastUpdateDate && (
      <span class="update-pill" title="Fecha de la última sesión registrada en el sistema">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Datos al {lastUpdateDate}
      </span>
    )}
  </div>

  <div class="stats-grid">
    <a href={CONGRESSMEN_PATH}>
      <div class="stat-card glass-panel">
        <h3>{stats.congressmen}</h3>
        <p class="text-muted">Diputados</p>
      </div>
    </a>

    <a href={DISTRICT_PATH}>
      <div class="stat-card glass-panel">
          <h3>{stats.districts}</h3>
          <p class="text-muted">Distritos</p>
      </div>
    </a>

    <a href={BLOCKS_PATH}>
      <div class="stat-card glass-panel">
        <h3>{stats.blocks}</h3>
        <p class="text-muted">Bancadas</p>
      </div>
    </a>

    <a href={PARTIES_PATH}>
      <div class="stat-card glass-panel">
          <h3>{stats.parties}</h3>
          <p class="text-muted">Partidos</p>
      </div>
    </a>

    <a href={SESSIONS_PATH}>
      <div class="stat-card glass-panel">
        <h3>{stats.sessions}</h3>
        <p class="text-muted">Sesiones</p>
      </div>
    </a>

    <a href={VOTES_PATH}>
      <div class="stat-card glass-panel">
        <h3>{stats.voting}</h3>
        <p class="text-muted">Votaciones</p>
      </div>
    </a>
  </div>
</Layout>

<style>
  .hero-section {
    padding: 4rem 0 3rem;
  }

  .update-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    padding: 0.35em 0.9em;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
  }

  .update-pill svg {
    flex-shrink: 0;
    opacity: 0.7;
  }
  
  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--text-light) 0%, var(--accent-color) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .hero-subtitle {
    margin: 0 0 1rem;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--text-muted);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    text-align: center;
    padding: 3rem 2rem;
  }

  .stat-card h3 {
    font-size: 3rem;
    color: var(--text-light);
    margin-bottom: 0.5rem;
  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 2rem 0 1.5rem;
    }
    .hero-title {
      font-size: 2rem;
    }
    .hero-subtitle {
      font-size: 1rem;
    }
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .stat-card {
      padding: 1.5rem 1rem;
    }
    .stat-card h3 {
      font-size: 2rem;
    }
  }

  @media (max-width: 400px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
