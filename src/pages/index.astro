---
import Layout from '../layouts/Layout.astro';
import db from '../lib/db.js';

// Get high-level metrics for the landing page
const stats = {
  congressmen: db.prepare('SELECT COUNT(*) as count FROM congressmen').get().count,
  parties: db.prepare('SELECT COUNT(*) as count FROM parties').get().count,
  sessions: db.prepare('SELECT COUNT(*) as count FROM sessions').get().count,
  votations: db.prepare('SELECT COUNT(*) as count FROM votations').get().count
};
---

<Layout title="Inicio">
  <div class="hero-section text-center">
    <h1 class="hero-title">Audita a tu Congreso</h1>
    <p class="hero-subtitle text-muted">
      Explora, compara y recuerda cómo han votado y participado tus representantes. 
      Toma decisiones informadas para las próximas elecciones.
    </p>
  </div>

  <div class="stats-grid">
    <div class="stat-card glass-panel">
      <h3>{stats.congressmen}</h3>
      <p class="text-muted">Diputados</p>
      <a href="/congressmen" class="btn-link">Ver todos &rarr;</a>
    </div>
    
    <div class="stat-card glass-panel">
      <h3>{stats.parties}</h3>
      <p class="text-muted">Bancadas</p>
      <a href="/parties" class="btn-link">Ver agrupaciones &rarr;</a>
    </div>
    
    <div class="stat-card glass-panel">
      <h3>{stats.sessions}</h3>
      <p class="text-muted">Sesiones</p>
      <a href="/sessions" class="btn-link">Ver historial &rarr;</a>
    </div>
    
    <div class="stat-card glass-panel">
      <h3>{stats.votations}</h3>
      <p class="text-muted">Votaciones</p>
      <a href="/votations" class="btn-link">Explorar votos &rarr;</a>
    </div>
  </div>
</Layout>

<style>
  .hero-section {
    padding: 4rem 0 3rem;
  }
  
  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--text-light) 0%, var(--accent-color) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .hero-subtitle {
    font-size: 1.2rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    text-align: center;
    padding: 2.5rem 1.5rem;
  }

  .stat-card h3 {
    font-size: 3rem;
    color: var(--text-light);
    margin-bottom: 0.5rem;
  }

  .btn-link {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.95rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 2rem 0 1.5rem;
    }
    .hero-title {
      font-size: 2rem;
    }
    .hero-subtitle {
      font-size: 1rem;
    }
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .stat-card {
      padding: 1.5rem 1rem;
    }
    .stat-card h3 {
      font-size: 2rem;
    }
  }

  @media (max-width: 400px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
