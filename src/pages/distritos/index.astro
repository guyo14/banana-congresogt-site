---
import Layout from '../../layouts/Layout.astro';
import db from '../../lib/db.js';
import MarkedMap from "../../components/MarkedMap.astro";
import OrgCard from "../../components/OrgCard.astro";
import type {NoParams} from "../../lib/types.ts";
import {getDistrictPath} from "../../lib/paths.ts";

interface District {
  id: number;
  name: string;
  key: string;
  membersCount: number;
}

// Get districts with member count
const districts = db.prepare<NoParams, District>(`
  SELECT
    d.id,
    d.name,
    d.key,
    COUNT(*) AS membersCount
  FROM districts d
  LEFT JOIN congressmen c ON d.id = c.district_id
  GROUP BY d.id, d.name, d.key
  ORDER BY d.name, membersCount DESC
`).all();
---

<Layout title="Distritos Electorales">
  <div class="page-header">
    <h1>Distritos Electorales</h1>
  </div>

  <div class="grid-cards">
    {districts.map(({id, name, key, membersCount}) =>
      <OrgCard name={name} membersCount={membersCount} href={getDistrictPath(id)}>
          <MarkedMap districtMarked={key} cssClass="fit"/>
      </OrgCard>
    )}
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .district-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 2rem;
    min-height: 150px;
  }

  .district-card h3 {
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .badge-district {
    background: rgba(139, 148, 158, 0.15);
    border-color: rgba(139, 148, 158, 0.3);
    color: var(--text-main);
    font-size: 1rem;
    padding: 0.4rem 1rem;
  }

  .district-card:hover h3 {
    text-decoration: underline;
  }
</style>
