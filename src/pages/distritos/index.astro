---
import Layout from '../../layouts/Layout.astro';
import db from '../../lib/db.js';
import MarkedMap from "../../components/MarkedMap.astro";
import OrgCard from "../../components/OrgCard.astro";

// Get distritos with member count
const districts = db.prepare(`
    SELECT
        d.id,
        d.name,
        d.key,
        COUNT(DISTINCT c.id) AS member_count,

        -- Attendance rate across all members of this party
        ROUND(
                100.0 * SUM(CASE WHEN a.status = 'presente' THEN 1 ELSE 0 END)
                    / MAX(COUNT(a.session_id), 1)
            , 1) AS attendance_percent,

        -- Votes-in-favor rate across all votes cast by party members
        ROUND(
                100.0 * SUM(CASE WHEN v.vote_type = 'a_favor' THEN 1 ELSE 0 END)
                    / MAX(COUNT(v.voting_id), 1)
            , 1) AS in_favor_percent

    FROM congressmen c
    LEFT JOIN districts d ON d.id = c.district_id
    LEFT JOIN attendance a ON a.congressman_id = c.id
    LEFT JOIN votes v ON v.congressman_id = c.id
    GROUP BY d.id, d.name
    ORDER BY member_count DESC, d.name
`).all().map(d => ({
  id: d.id,
  name: d.name,
  key: d.key,
  href: `/distritos/${d.id}`,
  memberCount: d.member_count,
  attendancePercent: d.attendance_percent,
  inFavorPercent: d.in_favor_percent
}));
---

<Layout title="Distritos Electorales">
  <div class="page-header">
    <h1>Distritos Electorales</h1>
    <p class="text-muted">Representación geopolítica en el Congreso.</p>
  </div>

  <div class="grid-cards">
    {districts.map(({key, ...district}) =>
      <OrgCard {...district}>
          <MarkedMap districtMarked={key} cssClass="fit"/>
      </OrgCard>
    )}
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .district-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 2rem;
    min-height: 150px;
  }

  .district-card h3 {
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .badge-district {
    background: rgba(139, 148, 158, 0.15);
    border-color: rgba(139, 148, 158, 0.3);
    color: var(--text-main);
    font-size: 1rem;
    padding: 0.4rem 1rem;
  }

  .district-card:hover h3 {
    text-decoration: underline;
  }
</style>
