---
import Layout from "../../layouts/Layout.astro";
import OrgDetailLayout from "../../components/OrgDetailLayout.astro";
import {
  getAllDistrictsId,
  getDistrict,
  getDistrictMembers,
  getDistrictStatsByYear,
  getDistrictStatsTotal
} from "../../lib/queries.ts";
import { getDistrictImagePath } from "../../lib/paths.ts";

export async function getStaticPaths() {
  return getAllDistrictsId().map((d) => ({
    params: { id: d.id.toString() },
  }));
}

const id = Number.parseInt(Astro.params.id);

const district = getDistrict(id);

if (!district) throw new Error(`District with ID ${id} not found`);

const members = getDistrictMembers(id);

const totalStats = getDistrictStatsTotal(id);

if (!totalStats) throw new Error(`Districts stats for ID ${id} not found`);

const yearlyStats = getDistrictStatsByYear(id);
---

<Layout title={`Distrito ${district.name}`}>
  <OrgDetailLayout
    typeLabel="Distrito"
    imageSrc={getDistrictImagePath(id)}
    name={district.name}
    members={members}
    totalStats={totalStats}
    yearlyStats={yearlyStats}
  />
</Layout>
