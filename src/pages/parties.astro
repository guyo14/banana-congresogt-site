---
import Layout from '../layouts/Layout.astro';
import db from '../lib/db.js';

// Get parties with member count
const parties = db.prepare(`
  SELECT p.id, p.name, COUNT(c.id) as member_count
  FROM parties p
  LEFT JOIN congressmen c ON p.id = c.party_id
  GROUP BY p.id
  ORDER BY member_count DESC, p.name ASC
`).all();
---

<Layout title="Bancadas del Congreso">
  <div class="page-header">
    <h1>Bancadas del Congreso</h1>
    <p class="text-muted">Directorio de bloques y agrupaciones políticas.</p>
  </div>

  <div class="grid-cards">
    {parties.map(p => (
      <a href={`/party/${p.id}`} class="party-card glass-panel">
        <div class="card-info">
          <h3>{p.name}</h3>
          <span class="badge badge-party">{p.member_count} Diputados</span>
        </div>
      </a>
    ))}
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .party-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 2rem;
    min-height: 150px;
  }

  .party-card h3 {
    margin-bottom: 1rem;
    font-size: 1.5rem;
    color: var(--accent-color);
  }

  .badge-party {
    background: rgba(88, 166, 255, 0.15);
    color: var(--accent-color);
    border-color: rgba(88, 166, 255, 0.3);
    font-size: 1rem;
    padding: 0.4rem 1rem;
  }

  .party-card:hover h3 {
    text-decoration: underline;
  }
</style>
