---
import Layout from '../layouts/Layout.astro';
import {
  getActiveCongressmenWithTotalStats,
  getAllSimilarityPairs,
  getAllVotesOrderedByVotingNumber,
} from '../lib/queries.ts';

const congressmenData = getActiveCongressmenWithTotalStats();

const similarityData = getAllSimilarityPairs();

// Build a lookup map id1_id2 -> similarity row
const simLookup: Record<string, { similarityScore: number; commonVotes: number; sameVotes: number; agreementPercentage: number }> = {};
for (const s of similarityData) {
  simLookup[`${s.id1}_${s.id2}`] = s;
}

// Paired votes: for each voting, each congressman's vote type
// We'll build a map: votingId -> { subject, votes: { [congressmanId]: voteType } }
const allVotes = getAllVotesOrderedByVotingNumber();

const votingMap = new Map<number, { votingId: number; subject: string; votes: Record<number, number> }>();
for (const v of allVotes) {
  if (!votingMap.has(v.votingId)) {
    votingMap.set(v.votingId, { votingId: v.votingId, subject: v.subject, votes: {} });
  }
  votingMap.get(v.votingId)!.votes[v.congressmanId] = v.voteType;
}
const votingList = Array.from(votingMap.values());

const jsonCongressmen = JSON.stringify(congressmenData);
const jsonSimilarity = JSON.stringify(simLookup);
const jsonVotingList = JSON.stringify(votingList);
---

<Layout title="Comparar Diputados">
  <div class="page-header">
    <h1>Comparar Diputados</h1>
    <p class="text-muted">Selecciona dos diputados para comparar su desempeño.</p>
  </div>

  <!-- Slot selectors -->
  <div class="selector-bar">
    {[0, 1].map(i => (
      <div class="selector-slot glass-panel" id={`slot-${i}`}>
        <div class="selector-preview hidden" id={`preview-${i}`}>
          <img class="selector-preview-photo" id={`preview-photo-${i}`} alt="" />
        </div>
        <div class="selector-search-wrap">
          <input
            type="text"
            class="selector-input"
            placeholder={i === 0 ? 'Buscar primer diputado...' : 'Buscar segundo diputado...'}
            autocomplete="off"
            id={`input-${i}`}
          />
          <div class="selector-dropdown" id={`dropdown-${i}`}></div>
        </div>
        <button class="selector-clear hidden" id={`clear-${i}`} aria-label="Quitar">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    ))}
  </div>

  <!-- Empty state -->
  <div id="emptyState" class="empty-state glass-panel">
    <div class="empty-state-content">
      <strong>Selecciona dos diputados para comparar</strong>
      <p class="text-muted">Busca en los campos de arriba para comenzar la comparativa.</p>
    </div>
  </div>

  <!-- Comparison content (hidden until both selected) -->
  <div id="compareContent" class="compare-content hidden">
    <div class="share-bar">
      <button type="button" id="shareLinkBtn" class="share-link-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        <span id="shareLinkLabel">Copiar enlace</span>
      </button>
    </div>

    <!-- Shared similarity banner -->
    <div id="similarityBanner" class="similarity-banner glass-panel"></div>

    <!-- Profile comparison -->
    <div id="profileComparison" class="profile-comparison"></div>

    <!-- Metrics table -->
    <section class="section-card glass-panel">
      <h2 class="section-title" style="margin-top:0">Comparativa de Desempe&ntilde;o</h2>
      <div id="metricsTable" class="metrics-table"></div>
    </section>

    <!-- Paired voting -->
    <section class="section-card glass-panel" style="margin-top:2rem">
      <h2 class="section-title" style="margin-top:0">
        Historial de Votaciones <span class="vote-count-badge" id="votingCount">0</span>
      </h2>
      <div class="voting-filters">
        <div class="filter-group">
          <label for="searchVoting">Buscar por tema</label>
          <input type="text" id="searchVoting" class="filter-input" placeholder="Ej. Presupuesto..." />
        </div>
        <div class="filter-group">
          <label for="filterBehavior">Comportamiento</label>
          <select id="filterBehavior" class="filter-input">
            <option value="">---Todos---</option>
            <option value="same">Votaron igual</option>
            <option value="different">Votaron diferente</option>
            <option value="one_absent">Uno ausente</option>
            <option value="both_absent">Ambos ausentes</option>
          </select>
        </div>
      </div>
      <div class="voting-list" id="votingList"></div>
    </section>
  </div>
</Layout>

<script define:vars={{ jsonCongressmen, jsonSimilarity, jsonVotingList }}>
  const DATA = JSON.parse(jsonCongressmen);
  const SIM  = JSON.parse(jsonSimilarity);
  const VOTING = JSON.parse(jsonVotingList);

  const VOTE = { IN_FAVOR: 0, AGAINST: 1, ABSENT: 2 };
  const voteLabel = t => t === VOTE.IN_FAVOR ? 'A Favor' : t === VOTE.AGAINST ? 'En Contra' : 'Ausente';
  const voteColor = t => t === VOTE.IN_FAVOR ? '#00b2e3' : t === VOTE.AGAINST ? '#00da9f' : '#ffd700';

  const selected = [null, null];

  function calcAge(birthDate) {
    if (!birthDate) return '—';
    const today = new Date();
    const bd = new Date(birthDate);
    let age = today.getFullYear() - bd.getFullYear();
    const m = today.getMonth() - bd.getMonth();
    if (m < 0 || (m === 0 && today.getDate() < bd.getDate())) age--;
    return age;
  }

  function pct(num, den) {
    return den === 0 ? 0 : Math.round(1000 * num / den) / 10;
  }

  // Determine highlight: 'better' = higher is better, 'lower' = lower is better, 'neutral' = no highlight
  function highlightClass(v1, v2, mode) {
    if (v1 === v2 || mode === 'neutral') return ['', ''];
    if (mode === 'higher') return v1 > v2 ? ['val-better', ''] : ['', 'val-better'];
    if (mode === 'lower') return v1 < v2 ? ['val-better', ''] : ['', 'val-better'];
    return ['', ''];
  }

  function renderSimilarityBanner() {
    const el = document.getElementById('similarityBanner');
    const c1 = selected[0], c2 = selected[1];
    if (!c1 || !c2) { el.innerHTML = ''; return; }

    const key = `${c1.id}_${c2.id}`;
    const sim = SIM[key];

    if (!sim) {
      el.innerHTML = `
        <div class="sim-banner-content">
          <span class="sim-label">No hay datos de similitud disponibles entre estos diputados.</span>
        </div>`;
      return;
    }

    const scoreColor = sim.similarityScore >= 0.5 ? 'var(--color-favor)' :
                       sim.similarityScore >= 0 ? '#f0a500' : 'var(--color-contra)';
    const agrColor = sim.agreementPercentage >= 0.7 ? 'var(--color-favor)' :
                     sim.agreementPercentage >= 0.5 ? '#f0a500' : 'var(--color-contra)';

    el.innerHTML = `
      <div class="sim-banner-content">
        <div class="sim-stat">
          <span class="sim-stat-value" style="color:${agrColor}">${(sim.agreementPercentage * 100).toFixed(1)}%</span>
          <span class="sim-stat-label">Coincidencia</span>
        </div>
        <div class="sim-stat">
          <span class="sim-stat-value">${sim.sameVotes.toLocaleString()}</span>
          <span class="sim-stat-label">Votos iguales</span>
        </div>
        <div class="sim-stat">
          <span class="sim-stat-value">${sim.commonVotes.toLocaleString()}</span>
          <span class="sim-stat-label">Votaciones ambos presentes</span>
        </div>
      </div>`;
  }

  function renderProfiles() {
    const el = document.getElementById('profileComparison');
    const c1 = selected[0], c2 = selected[1];
    if (!c1 || !c2) { el.innerHTML = ''; return; }

    function profileCard(c) {
      return `
        <a href="/diputados/${c.id}" class="profile-card glass-panel">
          <img src="/diputados/${c.id}.jpg" alt="${c.firstName} ${c.lastName}" class="profile-photo" />
          <div class="profile-details">
            <span class="profile-name">${c.firstName} ${c.lastName}</span>
            <div class="profile-meta">
              <span class="profile-chip">${c.blockName}</span>
              <span class="profile-chip">${c.partyName || '—'}</span>
              <span class="profile-chip">${c.districtName}</span>
              <span class="profile-chip">${calcAge(c.birthDate)} a&ntilde;os</span>
            </div>
          </div>
        </a>`;
    }

    el.innerHTML = `
      <div class="profile-grid">
        ${profileCard(c1)}
        <div class="vs-divider">VS</div>
        ${profileCard(c2)}
      </div>`;
  }

  function renderMetrics() {
    const el = document.getElementById('metricsTable');
    const c1 = selected[0], c2 = selected[1];
    if (!c1 || !c2) { el.innerHTML = ''; return; }

    const totalSessions1 = c1.attendancePresent + c1.attendanceAbsent + c1.attendanceLicense;
    const totalSessions2 = c2.attendancePresent + c2.attendanceAbsent + c2.attendanceLicense;
    const totalVotes1 = c1.votesInFavor + c1.votesAgainst + c1.votesAbsent;
    const totalVotes2 = c2.votesInFavor + c2.votesAgainst + c2.votesAbsent;
    const participatedVotes1 = c1.votesInFavor + c1.votesAgainst;
    const participatedVotes2 = c2.votesInFavor + c2.votesAgainst;

    const metrics = [
      { label: 'Sesiones', section: true },
      { label: 'Asistencia', v1: c1.attendancePresent, v2: c2.attendancePresent, p1: pct(c1.attendancePresent, totalSessions1), p2: pct(c2.attendancePresent, totalSessions2), mode: 'higher', showPct: true },
      { label: 'Ausencias', v1: c1.attendanceAbsent, v2: c2.attendanceAbsent, p1: pct(c1.attendanceAbsent, totalSessions1), p2: pct(c2.attendanceAbsent, totalSessions2), mode: 'lower', showPct: true },
      { label: 'Licencias', v1: c1.attendanceLicense, v2: c2.attendanceLicense, p1: pct(c1.attendanceLicense, totalSessions1), p2: pct(c2.attendanceLicense, totalSessions2), mode: 'lower', showPct: true },
      { label: 'Total sesiones', v1: totalSessions1, v2: totalSessions2, mode: 'neutral' },
      { label: 'Votaciones', section: true },
      { label: 'A Favor', v1: c1.votesInFavor, v2: c2.votesInFavor, p1: pct(c1.votesInFavor, totalVotes1), p2: pct(c2.votesInFavor, totalVotes2), mode: 'neutral', showPct: true },
      { label: 'En Contra', v1: c1.votesAgainst, v2: c2.votesAgainst, p1: pct(c1.votesAgainst, totalVotes1), p2: pct(c2.votesAgainst, totalVotes2), mode: 'neutral', showPct: true },
      { label: 'Ausente en votaci\u00f3n', v1: c1.votesAbsent, v2: c2.votesAbsent, p1: pct(c1.votesAbsent, totalVotes1), p2: pct(c2.votesAbsent, totalVotes2), mode: 'lower', showPct: true },
      { label: 'Participaci\u00f3n en votaciones', v1: participatedVotes1, v2: participatedVotes2, p1: pct(participatedVotes1, totalVotes1), p2: pct(participatedVotes2, totalVotes2), mode: 'higher', showPct: true },
      { label: 'Alineaci\u00f3n con mayor\u00eda', section: true },
      { label: 'Con la mayor\u00eda', v1: c1.votesWithMajority, v2: c2.votesWithMajority, p1: pct(c1.votesWithMajority, participatedVotes1), p2: pct(c2.votesWithMajority, participatedVotes2), mode: 'neutral', showPct: true },
      { label: 'Contra la mayor\u00eda', v1: c1.votesAgainstMajority, v2: c2.votesAgainstMajority, p1: pct(c1.votesAgainstMajority, participatedVotes1), p2: pct(c2.votesAgainstMajority, participatedVotes2), mode: 'neutral', showPct: true },
    ];

    let html = `
      <div class="metrics-header">
        <div class="metrics-header-name">${c1.firstName} ${c1.lastName}</div>
        <div class="metrics-header-label">M\u00e9trica</div>
        <div class="metrics-header-name">${c2.firstName} ${c2.lastName}</div>
      </div>`;

    for (const m of metrics) {
      if (m.section) {
        html += `<div class="metrics-section-title">${m.label}</div>`;
        continue;
      }

      const [cls1, cls2] = highlightClass(
        m.showPct ? m.p1 : m.v1,
        m.showPct ? m.p2 : m.v2,
        m.mode
      );

      const val1Display = m.showPct ? `${m.v1.toLocaleString()} <span class="metrics-pct">(${m.p1}%)</span>` : m.v1.toLocaleString();
      const val2Display = m.showPct ? `${m.v2.toLocaleString()} <span class="metrics-pct">(${m.p2}%)</span>` : m.v2.toLocaleString();

      html += `
        <div class="metrics-row">
          <div class="metrics-val metrics-val-left ${cls1}">${val1Display}</div>
          <div class="metrics-label">${m.label}</div>
          <div class="metrics-val metrics-val-right ${cls2}">${val2Display}</div>
        </div>`;
    }

    el.innerHTML = html;
  }

  // Paired voting
  let pairedVotingCache = [];

  function buildPairedVoting() {
    const c1 = selected[0], c2 = selected[1];
    if (!c1 || !c2) { pairedVotingCache = []; return; }

    pairedVotingCache = [];
    for (const v of VOTING) {
      const vt1 = v.votes[c1.id];
      const vt2 = v.votes[c2.id];
      if (vt1 === undefined || vt2 === undefined) continue;
      pairedVotingCache.push({
        votingId: v.votingId,
        subject: v.subject,
        voteType1: vt1,
        voteType2: vt2,
      });
    }
  }

  function renderVoting() {
    const el = document.getElementById('votingList');
    const countEl = document.getElementById('votingCount');
    const c1 = selected[0], c2 = selected[1];
    if (!c1 || !c2) { el.innerHTML = ''; countEl.textContent = '0'; return; }

    const query = (document.getElementById('searchVoting')).value.toLowerCase().trim();
    const behavior = (document.getElementById('filterBehavior')).value;

    let filtered = pairedVotingCache;

    if (query) {
      filtered = filtered.filter(v => v.subject.toLowerCase().includes(query));
    }

    if (behavior === 'same') {
      filtered = filtered.filter(v => v.voteType1 === v.voteType2 && v.voteType1 !== VOTE.ABSENT);
    } else if (behavior === 'different') {
      filtered = filtered.filter(v => v.voteType1 !== v.voteType2 && v.voteType1 !== VOTE.ABSENT && v.voteType2 !== VOTE.ABSENT);
    } else if (behavior === 'one_absent') {
      filtered = filtered.filter(v => (v.voteType1 === VOTE.ABSENT) !== (v.voteType2 === VOTE.ABSENT));
    } else if (behavior === 'both_absent') {
      filtered = filtered.filter(v => v.voteType1 === VOTE.ABSENT && v.voteType2 === VOTE.ABSENT);
    }

    countEl.textContent = filtered.length.toString();

    if (filtered.length === 0) {
      el.innerHTML = '<div class="voting-empty">No se encontraron votaciones con este filtro.</div>';
      return;
    }

    el.innerHTML = filtered.map(v => {
      const same = v.voteType1 === v.voteType2;
      const bothAbsent = v.voteType1 === VOTE.ABSENT && v.voteType2 === VOTE.ABSENT;
      const oneAbsent = (v.voteType1 === VOTE.ABSENT) !== (v.voteType2 === VOTE.ABSENT);
      const rowClass = bothAbsent ? 'both-absent' : oneAbsent ? 'one-absent' : same ? 'same-vote' : 'diff-vote';

      return `
        <a href="/votaciones/${v.votingId}" class="voting-row ${rowClass}">
          <div class="voting-pill" style="background:${voteColor(v.voteType1)}22;border-color:${voteColor(v.voteType1)};color:${voteColor(v.voteType1)}">${voteLabel(v.voteType1)}</div>
          <div class="voting-subject">${v.subject}</div>
          <div class="voting-pill" style="background:${voteColor(v.voteType2)}22;border-color:${voteColor(v.voteType2)};color:${voteColor(v.voteType2)}">${voteLabel(v.voteType2)}</div>
        </a>`;
    }).join('');
  }

  // Autocomplete setup
  function setupSlot(idx) {
    const input = document.getElementById(`input-${idx}`);
    const dropdown = document.getElementById(`dropdown-${idx}`);
    const clearBtn = document.getElementById(`clear-${idx}`);

    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      dropdown.innerHTML = '';
      if (!q || q.length < 2) { dropdown.classList.remove('open'); return; }

      const matches = DATA
        .filter(c => `${c.firstName} ${c.lastName} ${c.partyName ?? ''} ${c.districtName ?? ''}`.toLowerCase().includes(q))
        .slice(0, 8);

      if (!matches.length) { dropdown.classList.remove('open'); return; }

      matches.forEach(c => {
        const item = document.createElement('div');
        item.className = 'dd-item';
        item.innerHTML = `
          <img src="/diputados/${c.id}.jpg" alt="" class="dd-photo" />
          <div class="dd-text">
            <span class="dd-name">${c.firstName} ${c.lastName}</span>
            <span class="dd-meta">${c.partyName ?? ''} · ${c.districtName ?? ''}</span>
          </div>`;
        item.addEventListener('mousedown', e => {
          e.preventDefault();
          selectCongressman(idx, c);
        });
        dropdown.appendChild(item);
      });
      dropdown.classList.add('open');
    });

    input.addEventListener('blur', () => {
      setTimeout(() => dropdown.classList.remove('open'), 150);
    });

    clearBtn.addEventListener('click', () => {
      selected[idx] = null;
      input.value = '';
      input.disabled = false;
      clearBtn.classList.add('hidden');
      dropdown.classList.remove('open');
      document.getElementById(`preview-${idx}`).classList.add('hidden');
      document.getElementById(`slot-${idx}`).classList.remove('selector-slot--selected');
      syncUrl();
      refresh();
    });
  }

  const URL_KEYS = ['a', 'b'];

  function syncUrl() {
    const params = new URLSearchParams(window.location.search);
    selected.forEach((c, i) => {
      if (c) params.set(URL_KEYS[i], String(c.id));
      else params.delete(URL_KEYS[i]);
    });
    const qs = params.toString();
    const url = window.location.pathname + (qs ? `?${qs}` : '');
    window.history.replaceState(null, '', url);
  }

  function applyUrlSelection() {
    const params = new URLSearchParams(window.location.search);
    URL_KEYS.forEach((key, idx) => {
      const raw = params.get(key);
      if (!raw) return;
      const id = Number.parseInt(raw, 10);
      if (Number.isNaN(id)) return;
      const c = DATA.find(d => d.id === id);
      if (c) selectCongressman(idx, c);
    });
  }

  function selectCongressman(idx, c) {
    selected[idx] = c;
    const input = document.getElementById(`input-${idx}`);
    const dropdown = document.getElementById(`dropdown-${idx}`);
    const clearBtn = document.getElementById(`clear-${idx}`);
    const preview = document.getElementById(`preview-${idx}`);
    const previewPhoto = document.getElementById(`preview-photo-${idx}`);
    const slot = document.getElementById(`slot-${idx}`);

    input.value = `${c.firstName} ${c.lastName}`;
    input.disabled = true;
    dropdown.classList.remove('open');
    clearBtn.classList.remove('hidden');
    previewPhoto.src = `/diputados/${c.id}.jpg`;
    preview.classList.remove('hidden');
    slot.classList.add('selector-slot--selected');
    syncUrl();
    refresh();
  }

  function refresh() {
    const emptyState = document.getElementById('emptyState');
    const content = document.getElementById('compareContent');
    const bothSelected = selected[0] && selected[1];

    emptyState.classList.toggle('hidden', bothSelected);
    content.classList.toggle('hidden', !bothSelected);

    if (bothSelected) {
      buildPairedVoting();
      renderSimilarityBanner();
      renderProfiles();
      renderMetrics();
      renderVoting();
    }
  }

  [0, 1].forEach(i => setupSlot(i));

  // Voting filters
  document.getElementById('searchVoting')?.addEventListener('input', renderVoting);
  document.getElementById('filterBehavior')?.addEventListener('change', renderVoting);

  // Share link
  const shareBtn = document.getElementById('shareLinkBtn');
  const shareLabel = document.getElementById('shareLinkLabel');
  let shareResetTimer = null;
  shareBtn?.addEventListener('click', async () => {
    const url = window.location.href;
    try {
      await navigator.clipboard.writeText(url);
      shareLabel.textContent = '¡Enlace copiado!';
    } catch {
      shareLabel.textContent = 'No se pudo copiar';
    }
    if (shareResetTimer) clearTimeout(shareResetTimer);
    shareResetTimer = setTimeout(() => {
      shareLabel.textContent = 'Copiar enlace';
    }, 2000);
  });

  // Restore selection from URL on load
  applyUrlSelection();
</script>

<style>
  .page-header { margin-bottom: 1.5rem; }

  .hidden { display: none !important; }

  /* ── Selector bar ────────────────────────────────── */
  .selector-bar {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .selector-slot {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    position: relative;
    z-index: 10;
    padding: 0.6rem 0.75rem;
    transition: border-color var(--transition-fast);
  }
  .selector-slot--selected {
    border-color: var(--accent-color);
  }
  .selector-preview {
    flex-shrink: 0;
  }
  .selector-preview-photo {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border-color);
  }
  .selector-slot--selected .selector-preview-photo {
    border-color: var(--accent-color);
  }
  .selector-search-wrap { flex: 1; position: relative; }
  .selector-input {
    width: 100%;
    padding: 0.65rem 0.85rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--bg-tertiary);
    color: var(--text-main);
    font-size: 0.92rem;
    font-family: inherit;
    outline: none;
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }
  .selector-input:focus { border-color: var(--accent-color); background: var(--bg-secondary); }
  .selector-input:disabled {
    background: transparent;
    border-color: transparent;
    color: var(--text-light);
    font-weight: 700;
    font-size: 0.95rem;
    padding-left: 0;
  }
  .selector-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0; right: 0;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    z-index: 100;
    overflow: hidden;
  }
  .selector-dropdown.open { display: block; }
  :global(.dd-item) {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.6rem 0.9rem;
    cursor: pointer;
    transition: background var(--transition-fast);
  }
