---
import Layout from "../../layouts/Layout.astro";
import OrgDetailLayout from "../../components/OrgDetailLayout.astro";
import {
  getAllPartiesId,
  getParty,
  getPartyMembers,
  getPartyStatsByYear,
  getPartyStatsTotal
} from "../../lib/queries.ts";
import { getPartyImagePath } from "../../lib/paths.ts";

export async function getStaticPaths() {
  return getAllPartiesId().map((p) => ({
    params: { id: p.id.toString() },
  }));
}

const id = Number.parseInt(Astro.params.id);

const party = getParty(id);

if (!party) throw new Error(`Party with ID ${id} not found`);

const members = getPartyMembers(id);

const totalStats = getPartyStatsTotal(id);

if (!totalStats) throw new Error(`Party stats for ID ${id} not found`);

const yearlyStats = getPartyStatsByYear(id);
---

<Layout title={`Partido ${party.shortName}`}>
  <OrgDetailLayout
    typeLabel="Partido Político"
    imageSrc={getPartyImagePath(id)}
    name={party.name}
    shortName={party.shortName}
    members={members}
    totalStats={totalStats}
    yearlyStats={yearlyStats}
  />
</Layout>
