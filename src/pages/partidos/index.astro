---
import Layout from "../../layouts/Layout.astro";
import db from "../../lib/db.js";
import OrgCard from "../../components/OrgCard.astro";
import type { NoParams } from "../../lib/types";
import { getPartyImagePath, getPartyPath } from "../../lib/paths";

interface Party {
  id: number;
  name: string;
  membersCount: number;
}

const parties = db
  .prepare<NoParams, Party>(
    `
  SELECT
    p.id,
    p.short_name AS name,
    COUNT(*) AS membersCount
  FROM parties p
  LEFT JOIN congressmen c ON p.id = c.party_id
  GROUP BY p.id, p.short_name
  ORDER BY p.short_name, membersCount DESC
`,
  )
  .all();
---

<Layout title="Bancadas del Congreso">
  <div class="page-header">
    <h1>Bancadas del Congreso</h1>
  </div>

  <div class="grid-cards">
    {
      parties.map(({ id, name, membersCount }) => (
        <OrgCard
          name={name}
          membersCount={membersCount}
          href={getPartyPath(id)}
        >
          <img src={getPartyImagePath(id)} alt={name} class="fit" />
        </OrgCard>
      ))
    }
  </div>
</Layout>
