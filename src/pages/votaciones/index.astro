---
import Layout from "../../layouts/Layout.astro";
import {
  getSessionTypeString,
  MAJORITY,
} from "../../lib/mappers.ts";
import {getVotingSummaries} from "../../lib/queries.ts";

const voting = getVotingSummaries();

// Distinct periods for filter dropdown
const periods = [...new Set(voting.map((v) => v.period))].sort(
  (a, b) => Number(b) - Number(a),
);

const formatDate = (dateString: string): string => {
  const options: Intl.DateTimeFormatOptions = {
    year: "numeric",
    month: "short",
    day: "numeric",
  };
  return new Date(dateString).toLocaleDateString("es-GT", options);
};
---

<Layout title="Votaciones">
  <div class="page-header">
    <h1>Votaciones</h1>
  </div>

  <!-- Filters — grid style matching sesiones/index.astro -->
  <div class="filters">
    <div class="filter-group" style="grid-column: span 2;">
      <label for="searchSubject">Buscar por Tema / Decreto</label>
      <input
        type="text"
        id="searchSubject"
        placeholder="Ej. Presupuesto, Estado de Calamidad..."
      />
    </div>
    <div class="filter-group">
      <label for="filterPeriod">Período</label>
      <select id="filterPeriod">
        <option value="">---Todos---</option>
        {periods.map((p) => <option value={p}>{p}</option>)}
      </select>
    </div>
    <div class="filter-group">
      <label for="filterMajority">Mayoría</label>
      <select id="filterMajority">
        <option value="">---Todas---</option>
        <option value={String(MAJORITY.IN_FAVOR)}>Mayoría a favor</option>
        <option value={String(MAJORITY.AGAINST)}>Mayoría en contra</option>
        <option value={String(MAJORITY.TIE)}>Empate</option>
      </select>
    </div>
  </div>

  <p class="results-count" id="resultsCount">{voting.length} votaciones</p>

  <div class="votation-list" id="votationList">
    {
      voting.map((v, index) => {
        const vTotal = v.votesInFavor + v.votesAgainst + v.votesAbsent;
        const pctFavor =
          vTotal > 0 ? ((v.votesInFavor / vTotal) * 100).toFixed(1) : "0";
        const pctContra =
          vTotal > 0 ? ((v.votesAgainst / vTotal) * 100).toFixed(1) : "0";
        const pctAbsent =
          vTotal > 0 ? ((v.votesAbsent / vTotal) * 100).toFixed(1) : "0";
        const typeLabel = getSessionTypeString(v.sessionType);
        const sessionTag = `${v.period} Sesión ${typeLabel} No. ${v.sessionNumber}`;

        return (
          <a
            href={`/votaciones/${v.id}`}
            class="votation-card glass-panel"
            data-subject={v.subject.toLowerCase()}
            data-period={v.period}
            data-majority={String(v.majority)}
          >
            <div class="votation-number">#{voting.length - index}</div>
            <div class="votation-info">
              <h3>{v.subject}</h3>
              <div class="meta-tags">
                <span class="badge">{sessionTag}</span>
                <span class="votation-date">
                  {formatDate(v.startDate)}
                </span>
              </div>
            </div>
            <div class="vote-summary">
              <div class="vs-row">
                <span class="vs-dot" style="background:#00b2e3" />
                <span class="vs-label">A Favor</span>
                <strong class="vs-value">{v.votesInFavor}</strong>
                <span class="vs-pct">{pctFavor}%</span>
              </div>
              <div class="vs-row">
                <span class="vs-dot" style="background:#00da9f" />
                <span class="vs-label">En Contra</span>
                <strong class="vs-value">{v.votesAgainst}</strong>
                <span class="vs-pct">{pctContra}%</span>
              </div>
              <div class="vs-row">
                <span class="vs-dot" style="background:#ffd700" />
                <span class="vs-label">Ausente</span>
                <strong class="vs-value">{v.votesAbsent}</strong>
                <span class="vs-pct">{pctAbsent}%</span>
              </div>
              <div class="vs-bar">
                <div
                  class="vs-seg"
                  style={`width:${pctFavor}%; background:#00b2e3`}
                />
                <div
                  class="vs-seg"
                  style={`width:${pctContra}%; background:#00da9f`}
                />
                <div
                  class="vs-seg"
                  style={`width:${pctAbsent}%; background:#ffd700`}
                />
              </div>
            </div>
          </a>
        );
      })
    }
  </div>
</Layout>

<script>
  const searchInput = document.getElementById(
    "searchSubject",
  ) as HTMLInputElement;
  const filterPeriod = document.getElementById(
    "filterPeriod",
  ) as HTMLSelectElement;
  const filterMajority = document.getElementById(
    "filterMajority",
  ) as HTMLSelectElement;
  const cards = document.querySelectorAll<HTMLElement>(".votation-card");
  const resultsCount = document.getElementById("resultsCount")!;

  function applyFilters() {
    const q = searchInput.value.toLowerCase().trim();
    const periodVal = filterPeriod.value;
    const majorityVal = filterMajority.value;

    let visible = 0;

    cards.forEach((card) => {
      const matchText = !q || card.dataset.subject!.includes(q);
      const matchPeriod = !periodVal || card.dataset.period === periodVal;
      const matchMajority =
        !majorityVal || card.dataset.majority === majorityVal;

      const show = matchText && matchPeriod && matchMajority;
      card.style.display = show ? "flex" : "none";
      if (show) visible++;
    });

    resultsCount.textContent = `${visible} votaciones`;
  }

  searchInput.addEventListener("input", applyFilters);
  filterPeriod.addEventListener("change", applyFilters);
  filterMajority.addEventListener("change", applyFilters);
</script>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  /* Filter grid — mirrors sesiones/index.astro */
  .filters {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .filter-group label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .filter-group input,
  .filter-group select {
    width: 100%;
    padding: 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    color: var(--text-main);
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .filter-group input:focus,
  .filter-group select:focus {
    border-color: var(--accent-color);
  }

  .results-count {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    padding-left: 0.25rem;
  }

  /* Votation list */
  .votation-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .votation-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.1rem 1.5rem;
    color: inherit;
    transition:
      border-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .votation-number {
    font-size: 0.95rem;
    font-weight: 800;
    color: var(--bg-tertiary);
    background: var(--text-muted);
    min-width: 46px;
    height: 46px;
    padding: 0 0.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .votation-info {
    flex: 1;
    min-width: 0;
  }
  .votation-info h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1rem;
    line-height: 1.35;
    color: var(--text-light);
  }

  .meta-tags {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .badge {
    background: var(--bg-tertiary);
    padding: 0.2em 0.65em;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .votation-date {
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  /* Vote summary — right side of card, matching sesiones/[id] pattern */
  .vote-summary {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 200px;
    flex-shrink: 0;
  }

  .vs-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
  }

  .vs-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .vs-label {
    color: var(--text-muted);
    min-width: 65px;
  }

  .vs-value {
    color: var(--text-light);
    min-width: 24px;
    text-align: right;
  }

  .vs-pct {
    color: var(--text-muted);
    min-width: 38px;
    text-align: right;
  }

  .vs-bar {
    display: flex;
    height: 5px;
    border-radius: 3px;
    overflow: hidden;
    background: var(--bg-tertiary);
    margin-top: 0.2rem;
  }

  .vs-seg {
    height: 100%;
  }

  /* Hover */
  .votation-card:hover {
    border-color: var(--accent-color);
    transform: translateX(5px);
  }
  .votation-card:hover .votation-number {
    background: var(--accent-color);
    color: var(--bg-color);
  }

  /* Responsive */
  @media (max-width: 960px) {
    .filters {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .filters {
      grid-template-columns: 1fr;
    }
    .filter-group[style*="span 2"] {
      grid-column: span 1;
    }
    .votation-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .vote-summary {
      min-width: unset;
      width: 100%;
    }
  }
</style>
