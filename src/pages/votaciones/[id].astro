---
import Layout from "../../layouts/Layout.astro";
import DoughnutChart from "../../components/DoughnutChart.astro";
import GroupedActionTabs from "../../components/GroupedActionTabs.astro";
import {
  getSessionTypeString,
  VOTE_TYPE,
  VOTE_TYPE_STRING,
} from "../../lib/mappers.ts";
import {getAllVotingId, getCongressmenVotingAction, getVotingById} from "../../lib/queries.ts";

export async function getStaticPaths() {
  return getAllVotingId().map((v) => ({
    params: { id: v.id.toString() },
  }));
}

const id = Number.parseInt(Astro.params.id);

// Fetch all voting IDs to compute the global number
const allVoting = getAllVotingId();
const globalNumber = allVoting.length - allVoting.findIndex((v) => v.id === id);

const voting = getVotingById(id);

if (!voting) throw new Error(`Voting ${id} not found`);

const votesList = getCongressmenVotingAction(id)

const formatDate = (dateString: string) => {
  const options: Intl.DateTimeFormatOptions = {
    year: "numeric",
    month: "long",
    day: "numeric",
  };
  return new Date(dateString).toLocaleDateString("es-GT", options);
};

const VOTE_ACTION_MAP = {
  [VOTE_TYPE.IN_FAVOR]: { label: VOTE_TYPE_STRING.IN_FAVOR, color: "#00b2e3" },
  [VOTE_TYPE.AGAINST]: { label: VOTE_TYPE_STRING.AGAINST, color: "#00da9f" },
  [VOTE_TYPE.ABSENT]: { label: VOTE_TYPE_STRING.ABSENT, color: "#ffd700" }
};

const VOTE_FILTERS = [
  { value: VOTE_TYPE.IN_FAVOR, label: VOTE_TYPE_STRING.IN_FAVOR },
  { value: VOTE_TYPE.AGAINST, label: VOTE_TYPE_STRING.AGAINST },
  { value: VOTE_TYPE.ABSENT, label: VOTE_TYPE_STRING.ABSENT }
];
---

<Layout title={`Votación #${globalNumber}: ${voting.subject.substring(0, 30)}...`}>
  <div class="page-header">
    <div class="header-meta">
      <span class="badge">
        #{globalNumber}
      </span>
      <span class="badge" style="background: var(--bg-tertiary)">
        {voting.period} Sesión {getSessionTypeString(voting.sessionType)} No. {voting.sessionNumber}
      </span>
      <span class="text-muted">{formatDate(voting.startDate)}</span>
    </div>
    <h1>{voting.subject}</h1>
  </div>

  <!-- Top row: Resultado General + Asistencia charts side by side -->
  <div class="stats-grid">
    <section class="section-card glass-panel">
      <h2 class="section-title">Resultado General</h2>
      <DoughnutChart
        labels={[
          VOTE_TYPE_STRING.IN_FAVOR,
          VOTE_TYPE_STRING.AGAINST,
          VOTE_TYPE_STRING.ABSENT,
        ]}
        data={[
          voting.votesInFavor,
          voting.votesAgainst,
          voting.votesAbsent,
        ]}
      />
    </section>

    <section class="section-card glass-panel">
      <h2 class="section-title">Asistencia en la Votación</h2>
      <DoughnutChart
        labels={[
          "Presente",
          "Licencia",
          "Ausente",
        ]}
        data={[
          voting.attendancePresent,
          voting.attendanceLicense,
          voting.attendanceAbsent,
        ]}
      />
    </section>
  </div>

  <section class="section-card glass-panel" style="margin-top: 2rem; margin-bottom: 2rem;">
    <h2 class="section-title">
      Detalle de Votación
      <span class="sort-note">{votesList.length} diputados</span>
    </h2>

    <GroupedActionTabs members={votesList} actionMap={VOTE_ACTION_MAP} filters={VOTE_FILTERS} />
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }
  .header-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .badge {
    background: var(--text-main);
    color: var(--bg-color);
    padding: 0.25em 0.75em;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 700;
  }

  /* Stats grid mirrors sesiones layout */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-size: 1.4rem;
    font-weight: 700;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 1.25rem;
    margin-top: 0;
    color: var(--text-light);
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .sort-note {
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  .section-card {
    padding: 1.5rem;
  }

  @media (max-width: 900px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
