---
import Layout from "../../layouts/Layout.astro";
import db from "../../lib/db.ts";
import DoughnutChart from "../../components/DoughnutChart.astro";
import GroupedActionTabs from "../../components/GroupedActionTabs.astro";
import type { NoParams, IdQuery } from "../../lib/types.ts";
import {
  getSessionTypeString,
  VOTE_TYPE,
  VOTE_TYPE_STRING,
} from "../../lib/mappers.ts";

export async function getStaticPaths() {
  const votingIds = db
    .prepare<NoParams, IdQuery>("SELECT id FROM voting")
    .all();
  return votingIds.map((v) => ({
    params: { id: v.id.toString() },
  }));
}

const id = Number.parseInt(Astro.params.id);

// Fetch all voting IDs to compute global number
const allVoting = db
  .prepare<NoParams, IdQuery>(
    `SELECT v.id FROM voting v JOIN sessions s ON v.session_id = s.id ORDER BY s.start_date DESC, v.id DESC`,
  )
  .all();
const globalNumber = allVoting.length - allVoting.findIndex((v) => v.id === id);

interface VotingDetail {
  id: number;
  subject: string;
  start_date: string;
  session_number: number;
  session_type: number;
  period: string;
  majority: number;
  votes_in_favor: number;
  votes_against: number;
  votes_absent: number;
  attendance_present: number;
  attendance_absent: number;
  attendance_license: number;
}

const voting = db
  .prepare<number, VotingDetail>(
    `
  SELECT 
    v.id, v.subject, s.start_date, s.session_number, s.type as session_type, s.period,
    v.majority,
    v.votes_in_favor, v.votes_against, v.votes_absent,
    v.attendance_present, v.attendance_absent, v.attendance_license
  FROM voting v
  JOIN sessions s ON v.session_id = s.id
  WHERE v.id = ?
`,
  )
  .get(id);

if (!voting) throw new Error(`Voting ${id} not found`);

interface VoteMember {
  action_value: number;
  congressman_id: number;
  first_name: string;
  last_name: string;
  party_id: number;
  party_name: string;
  district_id: number;
  district_name: string;
  block_id: number;
  block_name: string;
}

// Fetch individual votes for the tabs
const votesList = db
  .prepare<number, VoteMember>(
    `
  SELECT 
    v.vote_type as action_value, 
    c.id as congressman_id, c.first_name, c.last_name,
    p.id as party_id, COALESCE(p.name, 'Sin Partido') as party_name,
    d.id as district_id, COALESCE(d.name, 'Nacional') as district_name,
    COALESCE(c.block_id, -1) as block_id,
    CASE WHEN c.block_id = -1 THEN 'Independientes' ELSE COALESCE(b.name, 'Independientes') END as block_name
  FROM votes v
  JOIN congressmen c ON v.congressman_id = c.id
  LEFT JOIN parties p ON c.party_id = p.id
  LEFT JOIN districts d ON c.district_id = d.id
  LEFT JOIN blocks b ON c.block_id = b.id
  WHERE v.voting_id = ?
  ORDER BY block_name ASC, p.name ASC, c.first_name ASC
`,
  )
  .all(id);

const formatDate = (dateString: string) => {
  const options: Intl.DateTimeFormatOptions = {
    year: "numeric",
    month: "long",
    day: "numeric",
  };
  return new Date(dateString).toLocaleDateString("es-GT", options);
};

const VOTE_ACTION_MAP = {
  [VOTE_TYPE.IN_FAVOR]: { label: VOTE_TYPE_STRING.IN_FAVOR, color: "#00b2e3" },
  [VOTE_TYPE.AGAINST]: { label: VOTE_TYPE_STRING.AGAINST, color: "#00da9f" },
  [VOTE_TYPE.ABSENT]: { label: VOTE_TYPE_STRING.ABSENT, color: "#ffd700" }
};

const VOTE_FILTERS = [
  { value: VOTE_TYPE.IN_FAVOR, label: VOTE_TYPE_STRING.IN_FAVOR },
  { value: VOTE_TYPE.AGAINST, label: VOTE_TYPE_STRING.AGAINST },
  { value: VOTE_TYPE.ABSENT, label: VOTE_TYPE_STRING.ABSENT }
];
---

<Layout title={`Votación #${globalNumber}: ${voting.subject.substring(0, 30)}...`}>
  <div class="page-header">
    <div class="header-meta">
      <span class="badge">
        #{globalNumber}
      </span>
      <span class="badge" style="background: var(--bg-tertiary)">
        {voting.period} Sesión {getSessionTypeString(voting.session_type)} No. {voting.session_number}
      </span>
      <span class="text-muted">{formatDate(voting.start_date)}</span>
    </div>
    <h1>{voting.subject}</h1>
  </div>

  <!-- Top row: Resultado General + Asistencia charts side by side -->
  <div class="stats-grid">
    <section class="section-card glass-panel">
      <h2 class="section-title">Resultado General</h2>
      <DoughnutChart
        labels={[
          VOTE_TYPE_STRING.IN_FAVOR,
          VOTE_TYPE_STRING.AGAINST,
          VOTE_TYPE_STRING.ABSENT,
        ]}
        data={[
          voting.votes_in_favor,
          voting.votes_against,
          voting.votes_absent,
        ]}
      />
    </section>

    <section class="section-card glass-panel">
      <h2 class="section-title">Asistencia en la Votación</h2>
      <DoughnutChart
        labels={[
          "Presente",
          "Licencia",
          "Ausente",
        ]}
        data={[
          voting.attendance_present,
          voting.attendance_license,
          voting.attendance_absent,
        ]}
      />
    </section>
  </div>

  <section class="section-card glass-panel" style="margin-top: 2rem; margin-bottom: 2rem;">
    <h2 class="section-title">
      Detalle de Votación
      <span class="sort-note">{votesList.length} diputados</span>
    </h2>

    <GroupedActionTabs members={votesList} actionMap={VOTE_ACTION_MAP} filters={VOTE_FILTERS} />
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }
  .header-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .badge {
    background: var(--text-main);
    color: var(--bg-color);
    padding: 0.25em 0.75em;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 700;
  }

  /* Stats grid mirrors sesiones layout */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-size: 1.4rem;
    font-weight: 700;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 1.25rem;
    margin-top: 0;
    color: var(--text-light);
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .sort-note {
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  .section-card {
    padding: 1.5rem;
  }

  @media (max-width: 900px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
