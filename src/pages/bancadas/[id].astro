---
import Layout from "../../layouts/Layout.astro";
import AttendanceCharts from "../../components/AttendanceCharts.astro";
import VotesCharts from "../../components/VotesCharts.astro";
import RiceIndexChart from "../../components/RiceIndexChart.astro";
import MembersGrid from "../../components/MembersGrid.astro";
import {getAllBlocksId, getBlock, getBlockMembers, getBlockStatsByYear, getBlockStatsTotal} from "../../lib/queries.ts";

export async function getStaticPaths() {
  return getAllBlocksId().map((b) => ({
    params: { id: b.id.toString() },
  }));
}

const id = Number.parseInt(Astro.params.id);

const block = getBlock(id);

if (!block) throw new Error(`Block with ID ${id} not found`);

const members = getBlockMembers(id);

const totalStats = getBlockStatsTotal(id);

if (!totalStats) throw new Error(`Block stats for ID ${id} not found`);

const yearlyStats = getBlockStatsByYear(id);
---

<Layout title={`Bancada ${block.name}`}>
  <div class="page-header text-center">
    <div class="badge badge-party margin-auto mb-1">Bancada</div>
    <h1 class="district-name">{block.name}</h1>
    <p class="text-muted">{members.length} Representante(s)</p>
  </div>

  <RiceIndexChart
    overallIndex={totalStats.riceIndex}
    historyData={yearlyStats.map((stats) => ({
      sessionName: stats.period,
      index: stats.riceIndex,
    }))}
  />

  <div class="stats-grid">
    <div class="column-left">
      <AttendanceCharts
        total={{
          present: totalStats.attendancePresent,
          absent: totalStats.attendanceAbsent,
          license: totalStats.attendanceLicense,
        }}
        byYear={yearlyStats.map((stats) => ({
          period: stats.period,
          present: stats.attendancePresent,
          absent: stats.attendanceAbsent,
          license: stats.attendanceLicense,
        }))}
      />
    </div>

    <div class="column-right">
      <VotesCharts
        total={{
          inFavor: totalStats.votesInFavor,
          against: totalStats.votesAgainst,
          absent: totalStats.votesAbsent,
        }}
        byYear={yearlyStats.map((stats) => ({
          period: stats.period,
          inFavor: stats.votesInFavor,
          against: stats.votesAgainst,
          absent: stats.votesAbsent,
        }))}
      />
    </div>
  </div>

  <MembersGrid members={members} />
</Layout>

<style>
  .page-header {
    padding: 3rem 0 2rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
  }
  .district-name {
    font-size: 3rem;
    color: var(--text-light);
  }
  .margin-auto {
    margin: 0 auto;
  }
  .mb-1 {
    margin-bottom: 1rem;
  }
  .mb-3 {
    margin-bottom: 3rem;
  }
  .badge-district {
    background: rgba(139, 148, 158, 0.15);
    border-color: rgba(139, 148, 158, 0.3);
    color: var(--text-main);
  }
  .badge-party {
    background: rgba(88, 166, 255, 0.15);
    color: var(--accent-color);
    border-color: rgba(88, 166, 255, 0.3);
    font-size: 0.75rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
    min-width: 0;
    margin-top: 2rem;
    margin-bottom: 3rem;
  }
  .stats-grid > * {
    min-width: 0;
  }

  @media (max-width: 900px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .district-name {
      font-size: 2rem;
    }
  }
</style>
