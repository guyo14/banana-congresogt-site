---
import Layout from "../../layouts/Layout.astro";
import db from "../../lib/db.js";
import type { IdQuery, NoParams, OrgStats } from "../../lib/types.ts";
import { PERIOD, CONGRESSMAN_STATUS } from "../../lib/mappers.ts";
import AttendanceCharts from "../../components/AttendanceCharts.astro";
import VotesCharts from "../../components/VotesCharts.astro";
import RiceIndexChart from "../../components/RiceIndexChart.astro";
import MembersGrid from "../../components/MembersGrid.astro";

export async function getStaticPaths() {
  const blocks = db
    .prepare<NoParams, IdQuery>("SELECT id FROM blocks")
    .all();
  return blocks.map((b) => ({
    params: { id: b.id.toString() },
  }));
}

const id = Number.parseInt(Astro.params.id);

interface Block {
  id: number;
  name: string;
  shortName: string;
}

interface Congressman {
  id: number;
  firstName: string;
  lastName: string;
  badge: string;
}

const block = db.prepare<number, Block>(`
  SELECT
    id,
    name,
    short_name AS shortName
  FROM blocks
  WHERE id = ?
`).get(id);

if (!block) throw new Error(`Block with ID ${id} not found`);

const members = db
  .prepare<NoParams, Congressman>(
    `
  SELECT
    c.id,
    c.first_name AS firstName,
    c.last_name AS lastName,
    d.name as badge 
  FROM congressmen c
  LEFT JOIN districts d ON c.district_id = d.id
  WHERE c.block_id = ? AND c.status = ${CONGRESSMAN_STATUS.ACTIVE}
  ORDER BY c.first_name, c.last_name
`,
  )
  .all(id);

const totalStats = db
  .prepare<number, OrgStats>(
    `
  SELECT
    attendance_present AS attendancePresent,
    attendance_absent AS attendanceAbsent,
    attendance_license AS attendanceLicense,
    votes_in_favor AS votesInFavor,
    votes_against AS votesAgainst,
    votes_absent AS votesAbsent,
    rice_index AS riceIndex
  FROM block_stats
  WHERE id = ? AND period = '${PERIOD.TOTAL}'
`,
  )
  .get(id);

if (!totalStats) throw new Error(`Block stats for ID ${id} not found`);

const yearlyStats = db
  .prepare<number, OrgStats>(
    `
  SELECT
    period,
    attendance_present AS attendancePresent,
    attendance_absent AS attendanceAbsent,
    attendance_license AS attendanceLicense,
    votes_in_favor AS votesInFavor,
    votes_against AS votesAgainst,
    votes_absent AS votesAbsent,
    rice_index AS riceIndex
  FROM block_stats
  WHERE id = ? AND period != '${PERIOD.TOTAL}'
  ORDER BY period
`,
  )
  .all(id);
---

<Layout title={`Bancada ${block.name}`}>
  <div class="page-header text-center">
    <div class="badge badge-party margin-auto mb-1">Bancada</div>
    <h1 class="district-name">{block.name}</h1>
    <p class="text-muted">{members.length} Representante(s)</p>
  </div>

  <RiceIndexChart
    overallIndex={totalStats.riceIndex}
    historyData={yearlyStats.map((stats) => ({
      sessionName: stats.period,
      index: stats.riceIndex,
    }))}
  />

  <div class="stats-grid">
    <div class="column-left">
      <AttendanceCharts
        total={{
          present: totalStats.attendancePresent,
          absent: totalStats.attendanceAbsent,
          license: totalStats.attendanceLicense,
        }}
        byYear={yearlyStats.map((stats) => ({
          period: stats.period,
          present: stats.attendancePresent,
          absent: stats.attendanceAbsent,
          license: stats.attendanceLicense,
        }))}
      />
    </div>

    <div class="column-right">
      <VotesCharts
        total={{
          inFavor: totalStats.votesInFavor,
          against: totalStats.votesAgainst,
          absent: totalStats.votesAbsent,
        }}
        byYear={yearlyStats.map((stats) => ({
          period: stats.period,
          inFavor: stats.votesInFavor,
          against: stats.votesAgainst,
          absent: stats.votesAbsent,
        }))}
      />
    </div>
  </div>

  <MembersGrid members={members} />
</Layout>

<style>
  .page-header {
    padding: 3rem 0 2rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
  }
  .district-name {
    font-size: 3rem;
    color: var(--text-light);
  }
  .margin-auto {
    margin: 0 auto;
  }
  .mb-1 {
    margin-bottom: 1rem;
  }
  .mb-3 {
    margin-bottom: 3rem;
  }
  .badge-district {
    background: rgba(139, 148, 158, 0.15);
    border-color: rgba(139, 148, 158, 0.3);
    color: var(--text-main);
  }
  .badge-party {
    background: rgba(88, 166, 255, 0.15);
    color: var(--accent-color);
    border-color: rgba(88, 166, 255, 0.3);
    font-size: 0.75rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
    min-width: 0;
    margin-top: 2rem;
    margin-bottom: 3rem;
  }
  .stats-grid > * {
    min-width: 0;
  }

  @media (max-width: 900px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .district-name {
      font-size: 2rem;
    }
  }
</style>
