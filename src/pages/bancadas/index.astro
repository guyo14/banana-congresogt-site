---
import Layout from '../../layouts/Layout.astro';
import OrgCard from '../../components/OrgCard.astro';
import {getBlockImagePath, getBlockPath} from "../../lib/paths.ts";
import {getAllBlocksWithMembersCount} from "../../lib/queries.ts";

const blocks = getAllBlocksWithMembersCount();
---

<Layout title="Bancadas del Congreso">
    <div class="page-header">
        <h1>Bancadas del Congreso</h1>
    </div>

    <div class="grid-cards">
        {blocks.map(({id, shortName, membersCount}) =>
          <OrgCard name={shortName} membersCount={membersCount} href={getBlockPath(id)}>
              <img src={getBlockImagePath(id)} alt={shortName} class="fit"/>
          </OrgCard>
        )}
    </div>
</Layout>
