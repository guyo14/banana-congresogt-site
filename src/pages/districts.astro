---
import Layout from '../layouts/Layout.astro';
import db from '../lib/db.js';

// Get districts with member count
const districts = db.prepare(`
  SELECT d.id, d.name, COUNT(c.id) as member_count
  FROM districts d
  LEFT JOIN congressmen c ON d.id = c.district_id
  GROUP BY d.id
  ORDER BY d.name ASC
`).all();
---

<Layout title="Distritos Electorales">
  <div class="page-header">
    <h1>Distritos Electorales</h1>
    <p class="text-muted">Representación geopolítica en el Congreso.</p>
  </div>

  <div class="grid-cards">
    {districts.map(d => (
      <a href={`/district/${d.id}`} class="district-card glass-panel">
        <div class="card-info">
          <h3>{d.name}</h3>
          <span class="badge badge-district">{d.member_count} Diputados</span>
        </div>
      </a>
    ))}
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .district-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 2rem;
    min-height: 150px;
  }

  .district-card h3 {
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .badge-district {
    background: rgba(139, 148, 158, 0.15);
    border-color: rgba(139, 148, 158, 0.3);
    color: var(--text-main);
    font-size: 1rem;
    padding: 0.4rem 1rem;
  }

  .district-card:hover h3 {
    text-decoration: underline;
  }
</style>
