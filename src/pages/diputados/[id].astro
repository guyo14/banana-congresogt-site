---
import Layout from "../../layouts/Layout.astro";
import AttendanceCharts from "../../components/AttendanceCharts.astro";
import VotesCharts from "../../components/VotesCharts.astro";
import {
  getBlockPath,
  getCongressmanPhotoPath,
  getDistrictPath,
  getPartyPath,
  getSessionPath,
  getVotingPath,
} from "../../lib/paths.ts";
import { VOTE_TYPE, VOTE_TYPE_STRING, CONGRESSMAN_STATUS } from "../../lib/mappers.ts";
import {
  getCongressmanStatusString,
  getSessionTypeString,
  getVoteString,
} from "../../lib/mappers.ts";
import { formatDate } from "../../lib/util.ts";
import {
  getAllCongressmenId,
  getAttendanceByCongressman,
  getCongressman, getCongressmanStatsByYear,
  getCongressmanStatsTotal, getVotesByCongressman
} from "../../lib/queries.ts";

export async function getStaticPaths() {
  return getAllCongressmenId().map((c) => ({
    params: { id: c.id.toString() },
  }));
}

const id = Number.parseInt(Astro.params.id);

const congressman = getCongressman(id);

if (!congressman) {
  throw new Error("Congressman not found");
}

const {
  firstName,
  lastName,
  dateOfBirth,
  status,
  partyId,
  partyName,
  districtId,
  districtName,
  blockId,
  blockName,
} = congressman;
const fullName = `${firstName} ${lastName}`;

const totalStats = getCongressmanStatsTotal(id);

if (!totalStats) {
  throw new Error("Total stats not found");
}

const attendance = getAttendanceByCongressman(id);

// Stats breakdown by year
const statsByYear = getCongressmanStatsByYear(id);

const votes = getVotesByCongressman(id);

// Utility for vote colors/labels
const getVoteColor = (type: number) => {
  if (type === VOTE_TYPE.IN_FAVOR) return "#00b2e3";
  if (type === VOTE_TYPE.AGAINST) return "#00da9f";
  return "#ffd700"; // ABSENT
};

// Heatmap structure grouped by year then month
// { year: { month: [{ status, day, label }] } }
const MONTH_NAMES = [
  "Ene",
  "Feb",
  "Mar",
  "Abr",
  "May",
  "Jun",
  "Jul",
  "Ago",
  "Sep",
  "Oct",
  "Nov",
  "Dic",
];
const heatmapData: Record<
  string,
  Record<string, Array<{ status: number; label: string; path: string }>>
> = {};
for (const a of attendance) {
  const d = new Date(a.sessionDate);
  const year = d.getFullYear();
  const month = d.getMonth(); // 0-indexed
  if (!heatmapData[year]) heatmapData[year] = {};
  if (!heatmapData[year][month]) heatmapData[year][month] = [];
  heatmapData[year][month].push({
    status: a.status,
    label: `${formatDate(d)} — Sesión ${getSessionTypeString(a.sessionType)} ${a.sessionNumber}`,
    path: getSessionPath(a.sessionId),
  });
}
const heatmapYears = Object.keys(heatmapData).sort();
---

<Layout title={fullName}>
  <div class="profile-hero">
    <div class="profile-photo-wrap">
      <img src={getCongressmanPhotoPath(id)} alt={fullName} loading="eager" />
    </div>
    <div class="profile-info">
      <span class="profile-type-label">Diputado/a</span>
      <h1 class="profile-name">{fullName}</h1>
      <div class="meta-chips">
        <a href={getDistrictPath(districtId)} class="meta-chip meta-chip-link">
          <span class="meta-chip-label">Distrito</span>
          <span class="meta-chip-value">{districtName}</span>
        </a>
        {blockId != null && (
          <a href={getBlockPath(blockId)} class="meta-chip meta-chip-link">
            <span class="meta-chip-label">Bancada</span>
            <span class="meta-chip-value">{blockName}</span>
          </a>
        )}
        <a href={getPartyPath(partyId)} class="meta-chip meta-chip-link">
          <span class="meta-chip-label">Partido</span>
          <span class="meta-chip-value">{partyName}</span>
        </a>
        <span class="meta-chip">
          <span class="meta-chip-label">Edad</span>
          <span class="meta-chip-value" id="age" data-birthdate={dateOfBirth}></span>
        </span>
      </div>
    </div>
  </div>

  <div class="stats-grid">
    <!-- Left Column: Attendance -->
    <div class="column-left">
      <AttendanceCharts
        total={{
          present: totalStats.attendancePresent,
          absent: totalStats.attendanceAbsent,
          license: totalStats.attendanceLicense,
        }}
        byYear={statsByYear.map((stats) => ({
          period: stats.period,
          present: stats.attendancePresent,
          absent: stats.attendanceAbsent,
          license: stats.attendanceLicense,
        }))}
      />

      <section
        class="section-card glass-panel sessions-history-card"
        style="margin-top: 2rem;"
      >
        <div class="heatmap-section">
          <h2 class="section-title" style="margin-top: 0;">Historial de Sesiones</h2>
          <div class="heatmap-legend">
            <span class="hm-legend-item"><span class="hm-dot status-0"></span> Presente</span>
            <span class="hm-legend-item"><span class="hm-dot status-2"></span> Licencia</span>
            <span class="hm-legend-item"><span class="hm-dot status-1"></span> Ausente</span>
          </div>
          {
            heatmapYears.map((year) => (
              <div class="heatmap-year">
                <div class="heatmap-year-label">{year}</div>
                <div class="heatmap-months">
                  {Array.from({ length: 12 }, (_, monthIdx) => {
                    const sessions = heatmapData[year]?.[monthIdx] ?? [];
                    return (
                      <div class="heatmap-month">
                        <div class="heatmap-month-name">
                          {MONTH_NAMES[monthIdx]}
                        </div>
                        <div class="heatmap-dots">
                          {sessions.map((s) => (
                            <div
                              class={`hm-dot status-${s.status}`}
                              data-label={s.label}
                              data-href={s.path}
                            />
                          ))}
                          {sessions.length === 0 && (
                            <div class="hm-dot hm-empty" />
                          )}
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            ))
          }
        </div>
      </section>
    </div>

    <!-- Right Column: Votes -->
    <div class="column-right">
      <VotesCharts
        total={{
          inFavor: totalStats.votesInFavor,
          against: totalStats.votesAgainst,
          absent: totalStats.votesAbsent,
        }}
        byYear={statsByYear.map((stats) => ({
          period: stats.period,
          inFavor: stats.votesInFavor,
          against: stats.votesAgainst,
          absent: stats.votesAbsent,
        }))}
      />

      <section
        class="section-card glass-panel votes-history-card"
        style="margin-top: 2rem;"
      >
        <div class="votes-section">
          <div class="votes-header">
            <h2 class="section-title" style="width: 100%; margin-bottom: 0; margin-top: 0;">
              Historial de Votaciones <span class="vote-count-badge"
                >{votes.length}</span
              >
            </h2>
          </div>
          <div
            class="filters"
            style="grid-template-columns: 1fr 1fr; margin-bottom: 1rem;"
          >
            <div class="filter-group">
              <label for="voteSearch">Buscar por tema</label>
              <input
                type="text"
                id="voteSearch"
                class="vote-search"
                placeholder="Ej. Presupuesto..."
              />
            </div>
            <div class="filter-group">
              <label for="filterVote">Filtrar por Voto</label>
              <select id="filterVote" class="vote-search">
                <option value="">---Todos---</option>
                <option value={VOTE_TYPE.IN_FAVOR}
                  >{VOTE_TYPE_STRING.IN_FAVOR}</option
                >
                <option value={VOTE_TYPE.AGAINST}
                  >{VOTE_TYPE_STRING.AGAINST}</option
                >
                <option value={VOTE_TYPE.ABSENT}
                  >{VOTE_TYPE_STRING.ABSENT}</option
                >
              </select>
            </div>
          </div>
          <div class="vote-list-scroll" id="voteList">
            {
              votes.map((v) => {
                const voteColor = getVoteColor(v.voteType);
                const voteLabel = getVoteString(v.voteType);
                return (
                  <a
                    href={getVotingPath(v.votingId)}
                    class="vote-row"
                    data-subject={v.subject.toLowerCase()}
                    data-type={v.voteType}
                  >
                    <div class="vote-row-left">
                      <div
                        class="vote-type-pill"
                        style={`background:${voteColor}22; border-color:${voteColor}; color:${voteColor}`}
                      >
                        {voteLabel}
                      </div>
                    </div>
                    <div class="vote-row-center">
                      <span class="vote-subject-text">{v.subject}</span>
                    </div>
                  </a>
                );
              })
            }
          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>

<script>
  // Calculate age
  document.addEventListener("DOMContentLoaded", () => {
    const spanAge = document.getElementById("age") as HTMLSpanElement;
    const birthDateStr = spanAge.dataset.birthdate;
    if (!birthDateStr) return;

    const today = new Date();
    const birthDate = new Date(birthDateStr);
    let age = today.getFullYear() - birthDate.getFullYear();
    const m = today.getMonth() - birthDate.getMonth();
    if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) {
      age--;
    }

    spanAge.replaceChildren(`${age} años`);
  });

  // Vote search and filter
  const voteSearch = document.getElementById("voteSearch") as HTMLInputElement;
  const filterVote = document.getElementById("filterVote") as HTMLSelectElement;
  const voteRows = document.querySelectorAll<HTMLElement>(".vote-row");

  function applyVoteFilters() {
    const q = voteSearch?.value.toLowerCase() || "";
    const typeVal = filterVote?.value || "";

    let visibleCount = 0;
    voteRows.forEach((row) => {
      const subject = (row.dataset.subject ?? "").toLowerCase();
      const type = row.dataset.type ?? "";

      const visible =
        subject.includes(q) && (typeVal === "" || type === typeVal);
      row.style.display = visible ? "flex" : "none";
      if (visible) visibleCount++;
    });

    // Opt: update the count badge
    const badge = document.querySelector(".vote-count-badge");
    if (badge) badge.textContent = visibleCount.toString();
  }

  voteSearch?.addEventListener("input", applyVoteFilters);
  filterVote?.addEventListener("change", applyVoteFilters);

  function syncHistoryCardHeights() {
    const sessionsCard = document.querySelector<HTMLElement>(
      ".sessions-history-card",
    );
    const votesCard = document.querySelector<HTMLElement>(
      ".votes-history-card",
    );
    if (!sessionsCard || !votesCard) return;

    // Stack layout on mobile/tablet keeps natural height.
    if (window.innerWidth <= 900) {
      votesCard.style.height = "";
      return;
    }

    const targetHeight = Math.round(
      sessionsCard.getBoundingClientRect().height,
    );
    votesCard.style.height = `${targetHeight}px`;
  }

  syncHistoryCardHeights();
  window.addEventListener("resize", syncHistoryCardHeights);

  // Heatmap dot tap-tooltip
  const hmTooltip = document.createElement('div');
  hmTooltip.className = 'hm-tooltip';
  document.body.appendChild(hmTooltip);

  // Stop clicks inside the tooltip (e.g. the link) from bubbling to the dismiss handler
  hmTooltip.addEventListener('click', (e) => e.stopPropagation());

  let activeDot: HTMLElement | null = null;

  function dismissTooltip() {
    hmTooltip.classList.remove('hm-tooltip--visible');
    activeDot = null;
  }

  document.querySelectorAll<HTMLElement>('.hm-dot[data-label]').forEach((dot) => {
    dot.addEventListener('click', (e) => {
      e.stopPropagation();

      if (activeDot === dot) {
        dismissTooltip();
        return;
      }

      activeDot = dot;

      const label = dot.dataset.label ?? '';
      const href  = dot.dataset.href ?? '';

      const link = document.createElement('a');
      link.href = href;
      link.textContent = label;
      hmTooltip.replaceChildren(link);
      hmTooltip.classList.add('hm-tooltip--visible');

      // Position: above the dot, centred horizontally, clamped to viewport
      const rect   = dot.getBoundingClientRect();
      const tw     = hmTooltip.offsetWidth;
      const th     = hmTooltip.offsetHeight;
      const margin = 10;

      let top  = rect.top - th - 10;
      let left = rect.left + rect.width / 2 - tw / 2;

      left = Math.max(margin, Math.min(left, window.innerWidth - tw - margin));
      const isAbove = top >= margin;
      if (!isAbove) top = rect.bottom + 10;

      // Arrow: point at the dot centre, clamped inside tooltip bounds
      const arrowX = (rect.left + rect.width / 2) - left;
      hmTooltip.style.setProperty('--arrow-x', `${Math.max(10, Math.min(arrowX, tw - 10))}px`);
      hmTooltip.classList.toggle('hm-tooltip--above', isAbove);
      hmTooltip.classList.toggle('hm-tooltip--below', !isAbove);

      hmTooltip.style.top  = `${top}px`;
      hmTooltip.style.left = `${left}px`;
    });
  });

  document.addEventListener('click', dismissTooltip);
</script>

<style>
  /* ---- Layout Grid ---- */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
    min-width: 0;
  }
  .stats-grid > * {
    min-width: 0;
  }
  @media (max-width: 900px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---- Profile hero header (mobile-first, matches PageHero) ---- */
  .profile-hero {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.25rem 1.25rem 1.25rem 1.5rem;
    margin-bottom: 2rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    position: relative;
    overflow: hidden;
  }
  .profile-hero::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: linear-gradient(
      to bottom,
      var(--accent-color),
      color-mix(in srgb, var(--accent-color) 20%, transparent)
    );
  }
  .profile-photo-wrap {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--border-color);
    background: var(--bg-tertiary);
  }
  .profile-photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .profile-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .profile-type-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-color);
  }
  .profile-name {
    font-size: 1.45rem;
    font-weight: 800;
    color: var(--text-light);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .meta-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }
  .meta-chip {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.35rem 0.65rem;
    border-radius: 8px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    min-width: 0;
  }
  .meta-chip-label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--text-muted);
    line-height: 1;
  }
  .meta-chip-value {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-main);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 160px;
    line-height: 1.3;
  }

  .meta-chip-link {
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }
  .meta-chip-link:hover {
    border-color: var(--accent-color);
    background: color-mix(in srgb, var(--accent-color) 5%, var(--bg-tertiary));
  }
  .meta-chip-link:hover .meta-chip-value {
    color: var(--accent-color);
  }

  @media (min-width: 560px) {
    .profile-hero {
      gap: 1.75rem;
      padding: 1.75rem 1.75rem 1.75rem 2rem;
    }
    .profile-photo-wrap {
      width: 96px;
      height: 96px;
    }
    .profile-name {
      font-size: 2rem;
    }
    .meta-chip-value {
      max-width: 220px;
    }
  }

  @media (min-width: 900px) {
    .profile-name {
      font-size: 2.4rem;
    }
  }


  /* ---- Heatmap ---- */
  .heatmap-section {
    padding-top: 0.5rem;
  }
  .heatmap-legend {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .hm-legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    white-space: nowrap;
  }
  .heatmap-year {
    margin-bottom: 1rem;
  }
  .heatmap-year-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
  }
  .heatmap-months {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 0.25rem;
  }
  .heatmap-month {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .heatmap-month-name {
    font-size: 0.6rem;
    color: var(--text-muted);
    text-align: center;
  }
  .heatmap-dots {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    align-items: center;
  }

  /* Tap tooltip for heatmap dots */
  :global(.hm-tooltip) {
    position: fixed;
    z-index: 9999;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 0.45rem 0.7rem;
    font-size: 0.78rem;
    line-height: 1.4;
    color: var(--text-main);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
    max-width: 220px;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.12s ease, transform 0.12s ease;
    font-family: inherit;
  }
  :global(.hm-tooltip--visible) {
    opacity: 1;
    transform: translateY(0);
  }
  :global(.hm-tooltip::after) {
    content: '';
    position: absolute;
    width: 8px;
    height: 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    left: var(--arrow-x, 50%);
    transform: translateX(-50%) rotate(45deg);
  }
  /* Arrow below tooltip body → points downward */
  :global(.hm-tooltip--above::after) {
    bottom: -5px;
    border-top-color: transparent;
    border-left-color: transparent;
  }
  /* Arrow above tooltip body → points upward */
  :global(.hm-tooltip--below::after) {
    top: -5px;
    border-bottom-color: transparent;
    border-right-color: transparent;
  }
  :global(.hm-tooltip a) {
    color: var(--accent-color);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent-color) 50%, transparent);
    text-underline-offset: 0.15em;
  }
  :global(.hm-tooltip a:hover) {
    color: var(--accent-hover);
    text-decoration-color: var(--accent-hover);
  }

  /* shared dot style for heatmap and legend */
  .hm-dot {
    width: 14px;
    height: 14px;
    cursor: help;
    flex-shrink: 0;
  }

  .hm-empty {
    background: var(--bg-tertiary);
    opacity: 0.3;
    border-radius: 3px;
  }
  .status-0 {
    background: #00b2e3;
    border-radius: 50%;
  } /* Presente: Circle */
  .status-1 {
    background: #ffd700;
    border-radius: 2px;
  } /* Ausente: Square */
  .status-2 {
    background: #00da9f;
    border-radius: 0;
    clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
  } /* Licencia: Diamond */

  /* ---- Votes List ---- */
  .votes-section {
    padding-top: 0.5rem;
  }
  .votes-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .vote-count-badge {
    background: var(--bg-tertiary);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.15em 0.6em;
    border-radius: 999px;
    border: 1px solid var(--border-color);
  }
  .vote-search,
  .filter-group select {
    padding: 0.55rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    color: var(--text-main);
    font-family: inherit;
    font-size: 0.9rem;
    min-width: 0;
    outline: none;
    width: 100%;
    transition: border-color var(--transition-fast);
  }
  .vote-search:focus,
  .filter-group select:focus {
    border-color: var(--accent-color);
  }

  .filters {
    display: grid;
    gap: 1rem;
  }
  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .filter-group label {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .vote-list-scroll {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-height: 500px;
    overflow-y: auto;
    padding-right: 0.25rem;
  }
  @media (min-width: 900px) {
    .votes-history-card {
      display: flex;
      flex-direction: column;
      min-height: 0;
    }
    .votes-history-card .votes-section {
      display: flex;
      flex-direction: column;
      height: 100%;
      min-height: 0;
    }
    .votes-history-card .vote-list-scroll {
      flex: 1;
      max-height: none;
      min-height: 0;
    }
  }
  .vote-list-scroll::-webkit-scrollbar {
    width: 5px;
  }
  .vote-list-scroll::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 3px;
  }

  .vote-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem;
    border-radius: 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    color: inherit;
    transition: border-color var(--transition-fast);
    text-decoration: none;
  }
  .vote-row:hover {
    border-color: var(--accent-color);
  }
  .vote-row-left {
    flex-shrink: 0;
    width: 90px;
    display: flex;
    justify-content: center;
  }
  .vote-row-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .vote-type-pill {
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.25em 0.6em;
    border-radius: 999px;
