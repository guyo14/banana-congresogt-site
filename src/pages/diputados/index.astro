---
import Layout from '../../layouts/Layout.astro';
import CongressmanCard from "../../components/CongressmanCard.astro";
import {CONGRESSMAN_STATUS, CONGRESSMAN_STATUS_STRING} from "../../lib/mappers.ts";
import {getAllCongressmen, getAllSimpleBlocks, getAllSimpleDistricts} from "../../lib/queries.ts";

const congressmen = getAllCongressmen()

const blocks = getAllSimpleBlocks();
const districts = getAllSimpleDistricts();
---

<Layout title="Diputados">
  <div class="page-header">
    <h1>Diputados del Congreso</h1>
  </div>

  <div class="filters">
    <div class="filter-group">
      <label for="searchName">Buscar por Nombre</label>
      <input type="text" id="searchName" placeholder="Ej. Luis Fernando..." />
    </div>
    <div class="filter-group">
      <label for="filterBlock">Filtrar por Bancada</label>
      <select id="filterBlock">
        <option value="">---Todas---</option>
        <option value="-1">---Independientes---</option>
        {blocks.map(b => <option value={b.id}>{b.name}</option>)}
      </select>
    </div>
    <div class="filter-group">
      <label for="filterDistrict">Filtrar por Distrito</label>
      <select id="filterDistrict">
        <option value="">---Todos---</option>
        {districts.map(d => <option value={d.id}>{d.name}</option>)}
      </select>
    </div>
    <div class="filter-group">
      <label for="filterStatus">Filtrar por estado</label>
      <select id="filterStatus">
        <option value="">---Todos---</option>
        <option value={CONGRESSMAN_STATUS.ACTIVE}>{CONGRESSMAN_STATUS_STRING.ACTIVE}</option>
        <option value={CONGRESSMAN_STATUS.INACTIVE}>{CONGRESSMAN_STATUS_STRING.INACTIVE}</option>
      </select>
    </div>
  </div>

  <div class="grid-cards" id="congressmanList">
    {congressmen.map(c => <CongressmanCard
            id={c.id}
            firstName={c.firstName}
            lastName={c.lastName}
            status={c.status}
            blockId={c.blockId}
            blockName={c.blockName}
            districtId={c.districtId}
            districtName={c.districtName} />)}
  </div>
</Layout>

<script>
  const searchName = document.getElementById('searchName') as HTMLInputElement;
  const filterBlock = document.getElementById('filterBlock') as HTMLSelectElement;
  const filterDistrict = document.getElementById('filterDistrict') as HTMLSelectElement;
  const filterStatus = document.getElementById('filterStatus') as HTMLSelectElement;
  const list = document.getElementById('congressmanList') as HTMLElement;

  function getCards() {
    return Array.from(list.querySelectorAll('.congressman-card')) as HTMLElement[];
  }

  function applyFilters() {
    const nameVal = searchName.value.toLowerCase();
    const blockVal = filterBlock.value;
    const districtVal = filterDistrict.value;
    const statusVal = filterStatus.value;

    getCards().forEach(card => {
      const name = card.dataset.name ?? '';
      const block = card.dataset.block ?? '';
      const district = card.dataset.district ?? '';
      const status = card.dataset.status ?? '';

      const visible =
        name.includes(nameVal) &&
        (blockVal === '' || block === blockVal) &&
        (districtVal === '' || district === districtVal) &&
        (statusVal === '' || status === statusVal);

      card.style.display = visible ? 'flex' : 'none';
    });
  }

  searchName.addEventListener('input', applyFilters);
  filterBlock.addEventListener('change', applyFilters);
  filterDistrict.addEventListener('change', applyFilters);
  filterStatus.addEventListener('change', applyFilters);

  applyFilters();
</script>

<style>
  .filters {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  #congressmanList {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .filter-group label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .filter-group input, .filter-group select {
    width: 100%;
    padding: 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    color: var(--text-main);
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .filter-group input:focus, .filter-group select:focus {
    border-color: var(--accent-color);
  }

  @media (max-width: 1200px) {
    #congressmanList {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 960px) {
    .filters {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 860px) {
    #congressmanList {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    #congressmanList {
      grid-template-columns: 1fr;
    }
    .filters {
      grid-template-columns: 1fr;
    }
  }
</style>
