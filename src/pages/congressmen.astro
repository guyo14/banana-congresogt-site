---
import Layout from '../layouts/Layout.astro';
import db from '../lib/db.js';

const congressmen = db.prepare(`
  SELECT c.id, c.first_name, c.last_name, c.photo_url, c.status, p.name as party_name, d.name as district_name 
  FROM congressmen c 
  LEFT JOIN parties p ON c.party_id = p.id 
  LEFT JOIN districts d ON c.district_id = d.id
  ORDER BY c.first_name, c.last_name
`).all();

const parties = db.prepare('SELECT id, name FROM parties ORDER BY name').all();
const districts = db.prepare('SELECT id, name FROM districts ORDER BY name').all();
---

<Layout title="Diputados">
  <div class="page-header">
    <h1>Diputados del Congreso</h1>
    <p class="text-muted">Directorio completo de los representantes electos.</p>
  </div>

  <div class="filters glass-panel">
    <div class="filter-group">
      <label for="searchName">Buscar por Nombre</label>
      <input type="text" id="searchName" placeholder="Ej. Luis Fernando..." />
    </div>
    <div class="filter-group">
      <label for="filterParty">Filtrar por Bancada</label>
      <select id="filterParty">
        <option value="">Todas las bancadas</option>
        {parties.map(p => <option value={p.name}>{p.name}</option>)}
      </select>
    </div>
    <div class="filter-group">
      <label for="filterDistrict">Filtrar por Distrito</label>
      <select id="filterDistrict">
        <option value="">Todos los distritos</option>
        {districts.map(d => <option value={d.name}>{d.name}</option>)}
      </select>
    </div>
  </div>

  <div class="grid-cards" id="congressmanList">
    {congressmen.map(c => (
      <a href={`/congressman/${c.id}`} class="congressman-card glass-panel" data-name={`${c.first_name} ${c.last_name}`.toLowerCase()} data-party={c.party_name} data-district={c.district_name}>
        <div class="card-image">
          {c.photo_url ? (
            <img src={`/congressmen/face/${c.id}.jpg`} alt={`${c.first_name} ${c.last_name}`} loading="lazy" onerror="this.src='/placeholder.svg'; this.onerror=null;" />
          ) : (
             <div class="placeholder-img">👤</div>
          )}
        </div>
        <div class="card-info">
          <h3>{c.first_name} <br/> {c.last_name}</h3>
          <div class="tags">
            <span class="badge badge-party">{c.party_name}</span>
            <span class="badge badge-district">{c.district_name}</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</Layout>

<script>
  // Simple client-side filtering
  const searchName = document.getElementById('searchName');
  const filterParty = document.getElementById('filterParty');
  const filterDistrict = document.getElementById('filterDistrict');
  const cards = document.querySelectorAll('.congressman-card');

  function filterCards() {
    const nameVal = searchName.value.toLowerCase();
    const partyVal = filterParty.value;
    const districtVal = filterDistrict.value;

    cards.forEach(card => {
      const name = card.dataset.name;
      const party = card.dataset.party;
      const district = card.dataset.district;

      const matchesName = name.includes(nameVal);
      const matchesParty = partyVal === '' || party === partyVal;
      const matchesDistrict = districtVal === '' || district === districtVal;

      if (matchesName && matchesParty && matchesDistrict) {
        card.style.display = 'flex';
      } else {
        card.style.display = 'none';
      }
    });
  }

  searchName.addEventListener('input', filterCards);
  filterParty.addEventListener('change', filterCards);
  filterDistrict.addEventListener('change', filterCards);
</script>

<style>
  .page-header {
    margin-bottom: 2rem;
  }
  
  .filters {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .filter-group label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .filter-group input, .filter-group select {
    padding: 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    color: var(--text-main);
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .filter-group input:focus, .filter-group select:focus {
    border-color: var(--accent-color);
  }

  /* Congressman Card */
  .congressman-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: inherit;
    align-items: center;
    text-align: center;
  }

  .card-image {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--bg-tertiary);
    border: 3px solid var(--border-color);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder-img {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
  }

  .card-info h3 {
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .badge-party {
    background: rgba(88, 166, 255, 0.15);
    color: var(--accent-color);
    border-color: rgba(88, 166, 255, 0.3);
  }

  .badge-district {
    background: rgba(139, 148, 158, 0.15);
    border-color: rgba(139, 148, 158, 0.3);
  }

  @media (max-width: 768px) {
    .filters {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .card-image {
      width: 80px;
      height: 80px;
    }
    .card-info h3 {
      font-size: 0.95rem;
    }
    .congressman-card {
      padding: 1rem 0.75rem;
      gap: 0.75rem;
    }
  }
</style>
