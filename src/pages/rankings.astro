---
import Layout from '../layouts/Layout.astro';
import db from '../lib/db.ts';
import {
  getCongressmanPath,
  getCongressmanPhotoPath,
  getDistrictPath,
  getPartyPath,
  getPartyImagePath,
  getBlockPath,
  getBlockImagePath,
} from '../lib/paths.ts';
import {CONGRESSMAN_STATUS} from "../lib/mappers.ts";

function pct(num: number, denom: number): number {
  return denom > 0 ? Math.round((num / denom) * 1000) / 10 : 0;
}

const rawCongressmen = db.prepare(`
  SELECT
    c.id,
    c.first_name   AS firstName,
    c.last_name    AS lastName,
    COALESCE(b.short_name, 'Independiente') AS badge,
    cs.period,
    cs.attendance_present,
    cs.attendance_absent,
    cs.attendance_license,
    cs.votes_in_favor,
    cs.votes_against,
    cs.votes_absent,
    cs.votes_with_majority,
    cs.votes_against_majority
  FROM congressman_stats cs
  JOIN congressmen c ON cs.id = c.id
  LEFT JOIN blocks b ON c.block_id = b.id
  WHERE c.status = ${CONGRESSMAN_STATUS.ACTIVE}
`).all() as any[];

const rawParties = db.prepare(`
  SELECT p.id, p.short_name AS name, ps.period,
    ps.attendance_present, ps.attendance_absent, ps.attendance_license,
    ps.votes_in_favor, ps.votes_against, ps.votes_absent, ps.rice_index
  FROM party_stats ps JOIN parties p ON ps.id = p.id
`).all() as any[];

const rawDistricts = db.prepare(`
  SELECT d.id, d.name, ds.period,
    ds.attendance_present, ds.attendance_absent, ds.attendance_license,
    ds.votes_in_favor, ds.votes_against, ds.votes_absent, ds.rice_index
  FROM district_stats ds JOIN districts d ON ds.id = d.id
`).all() as any[];

const rawBlocks = db.prepare(`
  SELECT b.id, b.short_name AS name, bs.period,
    bs.attendance_present, bs.attendance_absent, bs.attendance_license,
    bs.votes_in_favor, bs.votes_against, bs.votes_absent, bs.rice_index
  FROM block_stats bs JOIN blocks b ON bs.id = b.id
`).all() as any[];

function groupByPeriod(rows: any[], fn: (row: any) => object): Record<string, object[]> {
  const out: Record<string, object[]> = {};
  for (const row of rows) {
    (out[row.period] ??= []).push(fn(row));
  }
  return out;
}

const allData = {
  congressmen: groupByPeriod(rawCongressmen, (row) => {
    const attT = row.attendance_present + row.attendance_absent + row.attendance_license;
    const votT = row.votes_in_favor + row.votes_against + row.votes_absent;
    return {
      name: `${row.firstName} ${row.lastName}`,
      badge: row.badge,
      path: getCongressmanPath(row.id),
      photo: getCongressmanPhotoPath(row.id),
      att_pct: pct(row.attendance_present, attT),
      att_present: row.attendance_present,
      att_absent: row.attendance_absent,
      att_license: row.attendance_license,
      att_total: attT,
      session_absence_pct: pct(row.attendance_absent + row.attendance_license, attT),
      session_license_pct: pct(row.attendance_license, attT),
      session_absent_pct:  pct(row.attendance_absent, attT),
      favor_pct: pct(row.votes_in_favor, votT),
      vote_in_favor: row.votes_in_favor,
      vote_against: row.votes_against,
      vote_absent: row.votes_absent,
      vote_present: row.votes_in_favor + row.votes_against,
      vote_total: votT,
      majority_pct: pct(row.votes_with_majority, votT),
      with_majority: row.votes_with_majority,
      minority_pct: pct(row.votes_against_majority, votT),
      with_minority: row.votes_against_majority,
      voting_attendance_pct: pct(row.votes_in_favor + row.votes_against, votT),
      voting_absence_pct:    pct(row.votes_absent, votT),
      voting_against_pct:    pct(row.votes_against, votT),
    };
  }),
  parties: groupByPeriod(rawParties, (row) => {
    const attT = row.attendance_present + row.attendance_absent + row.attendance_license;
    const votT = row.votes_in_favor + row.votes_against + row.votes_absent;
    return {
      name: row.name,
      path: getPartyPath(row.id),
      photo: getPartyImagePath(row.id),
      att_pct: pct(row.attendance_present, attT),
      att_present: row.attendance_present,
      att_total: attT,
      favor_pct: pct(row.votes_in_favor, votT),
      vote_in_favor: row.votes_in_favor,
      vote_total: votT,
      rice_index: Math.round(Number(row.rice_index) * 1000) / 10,
    };
  }),
  districts: groupByPeriod(rawDistricts, (row) => {
    const attT = row.attendance_present + row.attendance_absent + row.attendance_license;
    const votT = row.votes_in_favor + row.votes_against + row.votes_absent;
    return {
      name: row.name,
      path: getDistrictPath(row.id),
      photo: `/distritos/${row.id}.svg`,
      att_pct: pct(row.attendance_present, attT),
      att_present: row.attendance_present,
      att_total: attT,
      favor_pct: pct(row.votes_in_favor, votT),
      vote_in_favor: row.votes_in_favor,
      vote_total: votT,
      rice_index: Math.round(Number(row.rice_index) * 1000) / 10,
    };
  }),
  blocks: groupByPeriod(rawBlocks, (row) => {
    const attT = row.attendance_present + row.attendance_absent + row.attendance_license;
    const votT = row.votes_in_favor + row.votes_against + row.votes_absent;
    return {
      name: row.name,
      path: getBlockPath(row.id),
      photo: getBlockImagePath(row.id),
      att_pct: pct(row.attendance_present, attT),
      att_present: row.attendance_present,
      att_total: attT,
      favor_pct: pct(row.votes_in_favor, votT),
      vote_in_favor: row.votes_in_favor,
      vote_total: votT,
      rice_index: Math.round(Number(row.rice_index) * 1000) / 10,
    };
  }),
};
---

<Layout title="Ranking del Congreso">
  <div class="page-header">
    <h1>Ranking del Congreso</h1>
  </div>

  <div class="filters">
    <div class="filter-group">
      <label for="filterPeriod">Período</label>
      <select id="filterPeriod">
        <option value="total">Período Completo</option>
        <option value="2024">2024</option>
        <option value="2025">2025</option>
        <option value="2026">2026</option>
        <option value="2027">2027</option>
      </select>
    </div>
    <div class="filter-group">
      <label for="filterEntity">Entidad</label>
      <select id="filterEntity">
        <option value="congressmen">Diputados</option>
        <option value="districts">Distritos</option>
        <option value="parties">Partidos</option>
        <option value="blocks">Bancadas</option>
      </select>
    </div>
    <div class="filter-group">
      <label for="filterRanking">Ranking</label>
      <select id="filterRanking"></select>
    </div>
  </div>

  <p class="results-count" id="resultsCount"></p>

  <div class="filter-inline">
    <input type="text" id="searchName" placeholder="Buscar por nombre..." />
  </div>

  <div class="rank-table glass-panel">
    <div class="rank-header">
      <span class="col-rank">#</span>
      <span class="col-name">Nombre</span>
      <span class="col-value" id="colValueHeader">—</span>
    </div>
    <div id="rankBody"></div>
  </div>
</Layout>

<script define:vars={{ allData }}>
  const DATA = allData;

  const RANKINGS = {
    congressmen: [
      { value: 'att_pct',              label: 'Asistencia a Sesiones',    unit: '%' },
      { value: 'session_absence_pct',  label: 'Inasistencia a Sesiones',  unit: '%' },
      { value: 'session_license_pct',  label: 'Inasistencia con Licencia', unit: '%' },
      { value: 'session_absent_pct',   label: 'Inasistencia sin Licencia', unit: '%' },
      { value: 'voting_attendance_pct', label: 'Asistencia a Votaciones', unit: '%' },
      { value: 'voting_absence_pct',   label: 'Ausencia en Votaciones',   unit: '%' },
      { value: 'favor_pct',            label: 'Votos A Favor',            unit: '%' },
      { value: 'voting_against_pct',   label: 'Votos en Contra',          unit: '%' },
      { value: 'majority_pct',         label: 'Con Mayoría',              unit: '%' },
      { value: 'minority_pct',         label: 'Con Minoría',              unit: '%' },
    ],
    parties: [
      { value: 'att_pct',    label: 'Asistencia',    unit: '%' },
      { value: 'favor_pct',  label: 'Votos A Favor', unit: '%' },
      { value: 'rice_index', label: 'Índice Rice',   unit: '%' },
    ],
    districts: [
      { value: 'att_pct',    label: 'Asistencia',    unit: '%' },
      { value: 'favor_pct',  label: 'Votos A Favor', unit: '%' },
      { value: 'rice_index', label: 'Índice Rice',   unit: '%' },
    ],
    blocks: [
      { value: 'att_pct',    label: 'Asistencia',    unit: '%' },
      { value: 'favor_pct',  label: 'Votos A Favor', unit: '%' },
      { value: 'rice_index', label: 'Índice Rice',   unit: '%' },
    ],
  };

  const ENTITY_LABEL = {
    congressmen: 'diputados',
    parties:     'partidos',
    districts:   'distritos',
    blocks:      'bancadas',
  };

  const filterPeriod   = document.getElementById('filterPeriod');
  const filterEntity   = document.getElementById('filterEntity');
  const filterRanking  = document.getElementById('filterRanking');
  const searchName     = document.getElementById('searchName');
  const rankBody       = document.getElementById('rankBody');
  const resultsCount   = document.getElementById('resultsCount');
  const colValueHeader = document.getElementById('colValueHeader');

  function esc(str) {
    return String(str)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function barColor() {
    return '#00b2e3';
  }

  function getHelper(row, metric) {
    if (metric === 'att_pct')               return `${row.att_present} / ${row.att_total}`;
    if (metric === 'session_absence_pct')   return `${row.att_absent + row.att_license} / ${row.att_total}`;
    if (metric === 'session_license_pct')   return `${row.att_license} / ${row.att_total}`;
    if (metric === 'session_absent_pct')    return `${row.att_absent} / ${row.att_total}`;
    if (metric === 'voting_attendance_pct') return `${row.vote_present} / ${row.vote_total}`;
    if (metric === 'voting_absence_pct')    return `${row.vote_absent} / ${row.vote_total}`;
    if (metric === 'favor_pct')             return `${row.vote_in_favor} / ${row.vote_total}`;
    if (metric === 'voting_against_pct')    return `${row.vote_against} / ${row.vote_total}`;
    if (metric === 'majority_pct')          return `${row.with_majority} / ${row.vote_total}`;
    if (metric === 'minority_pct')          return `${row.with_minority} / ${row.vote_total}`;
    return '';
  }

  function syncRankingOptions() {
    const entity   = filterEntity.value;
    const current  = filterRanking.value;
    const rankings = RANKINGS[entity];
    filterRanking.innerHTML = rankings
      .map(r => `<option value="${r.value}"${r.value === current ? ' selected' : ''}>${esc(r.label)}</option>`)
      .join('');
  }

  function render() {
    const period  = filterPeriod.value;
    const entity  = filterEntity.value;
    const metric  = filterRanking.value;
    const query   = searchName.value.toLowerCase().trim();

    const rankings   = RANKINGS[entity];
    const rankingDef = rankings.find(r => r.value === metric) ?? rankings[0];

    colValueHeader.textContent = rankingDef.label;

    // Sort and assign permanent ranks before filtering
    const sorted = (DATA[entity]?.[period] ?? []).slice();
    sorted.sort((a, b) => (b[metric] ?? 0) - (a[metric] ?? 0));
    const ranked = sorted.map((row, i) => ({ ...row, rank: i + 1 }));

    // Filter preserves original rank numbers
    const visible = query ? ranked.filter(r => r.name.toLowerCase().includes(query)) : ranked;

    resultsCount.textContent = `${ranked.length} ${ENTITY_LABEL[entity]}`;

    if (visible.length === 0) {
      rankBody.innerHTML = '<p class="no-data">Sin resultados.</p>';
      return;
    }

    const isCongressman = entity === 'congressmen';

    rankBody.innerHTML = visible.map((row) => {
      const value = row[metric] ?? 0;
      const color = barColor(metric, value);
      const imgClass = isCongressman ? 'row-photo' : 'row-logo';

      const imgHtml = `<img src="${esc(row.photo)}" alt="" class="${imgClass}" loading="lazy" onerror="this.style.visibility='hidden';">`;

      const nameCol = `${imgHtml}
        <span class="row-info">
          <span class="row-fullname">${esc(row.name)}</span>
          ${row.badge ? `<span class="row-badge">${esc(row.badge)}</span>` : ''}
        </span>`;

      const helper = getHelper(row, metric);
      const barWidth = Math.min(100, Math.max(0, value));

      return `<a href="${esc(row.path)}" class="rank-row">
        <span class="col-rank rank-num">${row.rank}</span>
        <span class="col-name">${nameCol}</span>
        <span class="col-value">
          <span class="bar-track"><span class="bar-fill" style="width:${barWidth}%;background:${color}"></span></span>
          <span class="bar-meta">
            <span class="bar-value" style="color:${color}">${value}${rankingDef.unit}</span>
            ${helper ? `<span class="bar-helper">${esc(helper)}</span>` : ''}
          </span>
        </span>
      </a>`;
    }).join('');
  }

  filterPeriod.addEventListener('change', render);
  filterEntity.addEventListener('change', () => { syncRankingOptions(); render(); });
  filterRanking.addEventListener('change', render);
  searchName.addEventListener('input', render);

  syncRankingOptions();
  render();
</script>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .filters {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .filter-group label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .filter-group input,
  .filter-group select {
    width: 100%;
    padding: 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    color: var(--text-main);
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .filter-group input:focus,
  .filter-group select:focus {
    border-color: var(--accent-color);
  }

  .results-count {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    padding-left: 0.25rem;
  }

  .filter-inline {
    margin-bottom: 1.25rem;
  }

  .filter-inline input {
    width: 100%;
    padding: 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    color: var(--text-main);
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .filter-inline input:focus {
    border-color: var(--accent-color);
  }

  /* Table container */
  .rank-table {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .rank-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 1rem;
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border-color);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  /* Column widths — header (scoped) */
  .col-rank  { width: 36px; flex-shrink: 0; text-align: center; }
  .col-name  { flex: 1; min-width: 0; }
  .col-value { width: 240px; flex-shrink: 0; display: flex; align-items: center; gap: 0.5rem; }

  /* Dynamic rows */
  :global(.rank-row) {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--border-color);
    color: inherit;
    text-decoration: none;
    transition: background var(--transition-fast);
  }
  :global(.rank-row:last-child) { border-bottom: none; }
  :global(.rank-row:hover)      { background: var(--bg-tertiary); }

  :global(.rank-row .col-rank)  { width: 36px; flex-shrink: 0; text-align: center; }
  :global(.rank-row .col-name)  { flex: 1; min-width: 0; display: flex; align-items: center; gap: 0.65rem; }
  :global(.rank-row .col-value) { width: 240px; flex-shrink: 0; display: flex; align-items: center; gap: 0.5rem; }

  :global(.rank-num) {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-muted);
  }

  /* Person photo — circle */
  :global(.row-photo) {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    background: var(--bg-tertiary);
  }

  /* Org logo — rounded square */
  :global(.row-logo) {
    width: 34px;
    height: 34px;
    border-radius: 6px;
    object-fit: contain;
    flex-shrink: 0;
    background: var(--bg-tertiary);
    padding: 3px;
  }

  :global(.row-info) {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  :global(.row-fullname) {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-light);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.row-badge) {
    font-size: 0.72rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.bar-track) {
    flex: 1;
    height: 7px;
    background: var(--bg-tertiary);
    border-radius: 999px;
    overflow: hidden;
  }

  :global(.bar-fill) {
    display: block;
    height: 100%;
    border-radius: 999px;
  }

  :global(.bar-meta) {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
    min-width: 60px;
    gap: 0.1rem;
  }

  :global(.bar-value) {
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1.2;
    text-align: right;
  }

  :global(.bar-helper) {
    font-size: 0.65rem;
    color: var(--text-muted);
    font-weight: 400;
    line-height: 1.2;
    text-align: right;
  }

  :global(.no-data) {
    padding: 1.5rem 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .filters { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 640px) {
    .col-value { width: 150px; }
    :global(.rank-row .col-value) { width: 150px; }
  }

  @media (max-width: 480px) {
    .filters { grid-template-columns: 1fr; }

    .rank-header { padding: 0.5rem 0.75rem; gap: 0.5rem; }
    :global(.rank-row) { padding: 0.5rem 0.75rem; gap: 0.5rem; }
    :global(.rank-row .col-name) { gap: 0.4rem; }

    /* Keep the value visible but compact: drop the bar and helper fraction */
    .col-value { width: 60px; }
    :global(.rank-row .col-value) { width: 60px; flex-direction: column; gap: 0; }
    :global(.bar-track) { display: none; }
    :global(.bar-helper) { display: none; }
    :global(.bar-meta) { min-width: unset; align-items: center; }

    :global(.row-photo) { width: 28px; height: 28px; }
    :global(.row-logo)  { width: 28px; height: 28px; }
  }

  @media (max-width: 360px) {
    .col-rank { width: 24px; }
    :global(.rank-row .col-rank) { width: 24px; }
    :global(.row-photo) { width: 24px; height: 24px; }
    :global(.row-logo)  { width: 24px; height: 24px; }
  }
</style>
