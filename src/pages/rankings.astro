---
import Layout from '../layouts/Layout.astro';
import db from '../lib/db.ts';
import {
  getCongressmanPath,
  getCongressmanPhotoPath,
  getDistrictPath,
  getPartyPath,
  getPartyImagePath,
  getBlockPath,
  getBlockImagePath,
} from '../lib/paths.ts';
import {CONGRESSMAN_STATUS} from "../lib/mappers.ts";

function pct(num: number, denom: number): number {
  return denom > 0 ? Math.round((num / denom) * 1000) / 10 : 0;
}

const rawCongressmen = db.prepare(`
  SELECT
    c.id,
    c.first_name   AS firstName,
    c.last_name    AS lastName,
    COALESCE(b.short_name, 'Independiente') AS badge,
    cs.period,
    cs.attendance_present,
    cs.attendance_absent,
    cs.attendance_license,
    cs.votes_in_favor,
    cs.votes_against,
    cs.votes_absent,
    cs.votes_with_majority,
    cs.votes_against_majority
  FROM congressman_stats cs
  JOIN congressmen c ON cs.id = c.id
  LEFT JOIN blocks b ON c.block_id = b.id
  WHERE c.status = ${CONGRESSMAN_STATUS.ACTIVE}
`).all() as any[];

const rawParties = db.prepare(`
  SELECT p.id, p.short_name AS name, ps.period,
    ps.attendance_present, ps.attendance_absent, ps.attendance_license,
    ps.votes_in_favor, ps.votes_against, ps.votes_absent, ps.rice_index
  FROM party_stats ps JOIN parties p ON ps.id = p.id
`).all() as any[];

const rawDistricts = db.prepare(`
  SELECT d.id, d.name, ds.period,
    ds.attendance_present, ds.attendance_absent, ds.attendance_license,
    ds.votes_in_favor, ds.votes_against, ds.votes_absent, ds.rice_index
  FROM district_stats ds JOIN districts d ON ds.id = d.id
`).all() as any[];

const rawBlocks = db.prepare(`
  SELECT b.id, b.short_name AS name, bs.period,
    bs.attendance_present, bs.attendance_absent, bs.attendance_license,
    bs.votes_in_favor, bs.votes_against, bs.votes_absent, bs.rice_index
  FROM block_stats bs JOIN blocks b ON bs.id = b.id
`).all() as any[];

function groupByPeriod(rows: any[], fn: (row: any) => object): Record<string, object[]> {
  const out: Record<string, object[]> = {};
  for (const row of rows) {
    (out[row.period] ??= []).push(fn(row));
  }
  return out;
}

const allData = {
  congressmen: groupByPeriod(rawCongressmen, (row) => {
    const attT = row.attendance_present + row.attendance_absent + row.attendance_license;
    const votT = row.votes_in_favor + row.votes_against + row.votes_absent;
    const votP = row.votes_in_favor + row.votes_against;
    return {
      name: `${row.firstName} ${row.lastName}`,
      badge: row.badge,
      path: getCongressmanPath(row.id),
      photo: getCongressmanPhotoPath(row.id),
      att_pct: pct(row.attendance_present, attT),
      att_present: row.attendance_present,
      att_absent: row.attendance_absent,
      att_license: row.attendance_license,
      att_total: attT,
      session_absence_pct: pct(row.attendance_absent + row.attendance_license, attT),
      session_license_pct: pct(row.attendance_license, attT),
      session_absent_pct:  pct(row.attendance_absent, attT),
      vote_in_favor: row.votes_in_favor,
      vote_against: row.votes_against,
      vote_absent: row.votes_absent,
      vote_present: votP,
      vote_total: votT,
      majority_pct: pct(row.votes_with_majority, votP),
      with_majority: row.votes_with_majority,
      minority_pct: pct(row.votes_against_majority, votP),
      with_minority: row.votes_against_majority,
      voting_attendance_pct: pct(votP, votT),
      voting_absence_pct:    pct(row.votes_absent, votT),
      voting_against_pct:    pct(row.votes_against, votP),
      voting_in_favor_pct:   pct(row.votes_in_favor, votP),
    };
  }),
  parties: groupByPeriod(rawParties, (row) => {
    const attT = row.attendance_present + row.attendance_absent + row.attendance_license;
    const votT = row.votes_in_favor + row.votes_against + row.votes_absent;
    const votP = row.votes_in_favor + row.votes_against;
    return {
      name: row.name,
      path: getPartyPath(row.id),
      photo: getPartyImagePath(row.id),
      att_pct: pct(row.attendance_present, attT),
      att_present: row.attendance_present,
      att_total: attT,
      vote_present: votP,
      voting_in_favor_pct: pct(row.votes_in_favor, votP),
      vote_in_favor: row.votes_in_favor,
      vote_total: votT,
      rice_index: Math.round(Number(row.rice_index) * 1000) / 10,
    };
  }),
  districts: groupByPeriod(rawDistricts, (row) => {
    const attT = row.attendance_present + row.attendance_absent + row.attendance_license;
    const votT = row.votes_in_favor + row.votes_against + row.votes_absent;
    const votP = row.votes_in_favor + row.votes_against;
    return {
      name: row.name,
      path: getDistrictPath(row.id),
      photo: `/distritos/${row.id}.svg`,
      att_pct: pct(row.attendance_present, attT),
      att_present: row.attendance_present,
      att_total: attT,
      vote_present: votP,
      voting_in_favor_pct: pct(row.votes_in_favor, votP),
      vote_in_favor: row.votes_in_favor,
      vote_total: votT,
      rice_index: Math.round(Number(row.rice_index) * 1000) / 10,
    };
  }),
  blocks: groupByPeriod(rawBlocks, (row) => {
    const attT = row.attendance_present + row.attendance_absent + row.attendance_license;
    const votT = row.votes_in_favor + row.votes_against + row.votes_absent;
    const votP = row.votes_in_favor + row.votes_against;
    return {
      name: row.name,
      path: getBlockPath(row.id),
      photo: getBlockImagePath(row.id),
      att_pct: pct(row.attendance_present, attT),
      att_present: row.attendance_present,
      att_total: attT,
      vote_present: votP,
      voting_in_favor_pct: pct(row.votes_in_favor, votP),
      vote_in_favor: row.votes_in_favor,
      vote_total: votT,
      rice_index: Math.round(Number(row.rice_index) * 1000) / 10,
    };
  }),
};
---

<Layout title="Ranking del Congreso">
  <div class="page-header">
    <h1>Ranking del Congreso</h1>
  </div>

  <div class="filters">
    <div class="filter-group">
      <label for="filterPeriod">Período</label>
      <select id="filterPeriod">
        <option value="total">Período Completo</option>
        <option value="2024">2024</option>
        <option value="2025">2025</option>
        <option value="2026">2026</option>
        <option value="2027">2027</option>
      </select>
    </div>
    <div class="filter-group">
      <label for="filterEntity">Entidad</label>
      <select id="filterEntity">
        <option value="congressmen">Diputados</option>
        <option value="districts">Distritos</option>
        <option value="parties">Partidos</option>
        <option value="blocks">Bancadas</option>
      </select>
    </div>
    <div class="filter-group">
      <label for="filterRanking">Ranking</label>
      <select id="filterRanking"></select>
    </div>
  </div>

  <div class="ranking-info" id="rankingInfo" aria-live="polite">
    <svg class="ranking-info-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
    </svg>
    <div class="ranking-info-body">
      <p class="ranking-info-desc" id="rankingInfoDesc"></p>
      <p class="ranking-info-formula" id="rankingInfoFormula"></p>
    </div>
  </div>

  <p class="results-count" id="resultsCount"></p>

  <div class="filter-inline">
    <input type="text" id="searchName" placeholder="Buscar por nombre..." />
  </div>

  <div class="rank-table glass-panel">
    <div class="rank-header">
      <span class="col-rank">#</span>
      <span class="col-name">Nombre</span>
      <span class="col-value" id="colValueHeader">—</span>
    </div>
    <div id="rankBody"></div>
  </div>
</Layout>

<script define:vars={{ allData }}>
  const DATA = allData;

  const RANKINGS = {
    congressmen: [
      {
        value: 'att_pct', label: '% Asistencia a Sesiones', unit: '%',
        description: 'Porcentaje de sesiones plenarias a las que el diputado se presentó.',
        formula: 'sesiones presente ÷ total de sesiones',
      },
      {
        value: 'session_absence_pct', label: '% Inasistencia a Sesiones', unit: '%',
        description: 'Porcentaje de sesiones en las que el diputado no estuvo presente, ya sea con o sin licencia.',
        formula: 'sesiones ausente ÷ total de sesiones',
      },
      {
        value: 'session_license_pct', label: '% Inasistencia con Licencia', unit: '%',
        description: 'Porcentaje de sesiones en las que el diputado faltó con licencia.',
        formula: 'sesiones ausente con licencia ÷ total de sesiones',
      },
      {
        value: 'session_absent_pct', label: '% Inasistencia sin Licencia', unit: '%',
        description: 'Porcentaje de sesiones en las que el diputado faltó sin ninguna justificación.',
        formula: 'sesiones ausente sin justificación ÷ total de sesiones',
      },
      {
        value: 'voting_attendance_pct', label: '% Participación en Votaciones', unit: '%',
        description: 'Porcentaje de votaciones en las que el diputado emitió un voto real (a favor o en contra).',
        formula: '(votos a favor + votos en contra) ÷ total de votaciones',
      },
      {
        value: 'voting_absence_pct', label: '% Ausencia en Votaciones', unit: '%',
        description: 'Porcentaje de votaciones en las que el diputado figuró como ausente y no emitió voto.',
        formula: 'votaciones ausente ÷ total de votaciones',
      },
      {
        value: 'voting_in_favor_pct', label: '% Votos A Favor', unit: '%',
        description: 'Porcentaje de votos emitidos a favor sobre el total de votaciones en las que participó.',
        formula: 'votos a favor ÷ total de votaciones presente',
      },
      {
        value: 'voting_against_pct', label: '% Votos en Contra', unit: '%',
        description: 'Porcentaje de votos emitidos en contra sobre el total de votaciones en las que participó.',
        formula: 'votos en contra ÷ total de votaciones presente',
      },
      {
        value: 'majority_pct', label: '% Votos con Mayoría', unit: '%',
        description: 'Porcentaje de veces que el diputado votó en el mismo sentido que la mayoría en la votación.',
        formula: 'votos alineados con la mayoría ÷ total de votaciones presente',
      },
      {
        value: 'minority_pct', label: '% Votos con Minoría', unit: '%',
        description: 'Porcentaje de veces que el diputado votó en sentido contrario a la mayoría en la votación.',
        formula: 'votos contrarios a la mayoría ÷ total de votaciones presente',
      },
    ],
    parties: [
      {
        value: 'att_pct', label: 'Asistencia', unit: '%',
        description: 'Promedio de asistencia de todos los diputados del partido a las sesiones plenarias.',
        formula: 'sesiones presente ÷ total de sesiones (promedio del partido)',
      },
      {
        value: 'voting_in_favor_pct', label: 'Votos A Favor', unit: '%',
        description: 'Porcentaje de votos a favor emitidos por los diputados del partido sobre el total de votos registrados.',
        formula: 'votos a favor ÷ total de votos del partido',
      },
      {
        value: 'rice_index', label: 'Índice Rice', unit: '%',
        description: 'Mide la cohesión interna del partido en votaciones. Un valor alto (100%) indica que todos votan igual; un valor bajo (0%) indica división total.',
        formula: 'promedio de (|# a favor − # en contra| ÷ total votos emitidos) por votación',
      },
    ],
    districts: [
      {
        value: 'att_pct', label: 'Asistencia', unit: '%',
        description: 'Promedio de asistencia de los diputados del distrito a las sesiones plenarias.',
        formula: 'sesiones presente ÷ total de sesiones (promedio del distrito)',
      },
      {
        value: 'voting_in_favor_pct', label: 'Votos A Favor', unit: '%',
        description: 'Porcentaje de votos a favor emitidos por los diputados del distrito sobre el total de votos registrados.',
        formula: 'votos a favor ÷ total de votos del distrito',
      },
      {
        value: 'rice_index', label: 'Índice Rice', unit: '%',
        description: 'Mide la cohesión interna del distrito en votaciones. Un valor alto indica que los diputados votan de manera uniforme.',
        formula: 'promedio de (|# a favor − # en contra| ÷ total votos emitidos) por votación',
      },
    ],
    blocks: [
      {
        value: 'att_pct', label: 'Asistencia', unit: '%',
        description: 'Promedio de asistencia de los integrantes de la bancada a las sesiones plenarias.',
        formula: 'sesiones presente ÷ total de sesiones (promedio de la bancada)',
      },
      {
        value: 'voting_in_favor_pct', label: 'Votos A Favor', unit: '%',
        description: 'Porcentaje de votos a favor emitidos por los integrantes de la bancada sobre el total de votos registrados.',
        formula: 'votos a favor ÷ total de votos de la bancada',
      },
      {
        value: 'rice_index', label: 'Índice Rice', unit: '%',
        description: 'Mide la cohesión interna de la bancada en votaciones. Un valor alto indica que los miembros votan de manera uniforme; un valor bajo indica división interna.',
        formula: 'promedio de (|# a favor − # en contra| ÷ total votos emitidos) por votación',
      },
    ],
  };

  const ENTITY_LABEL = {
    congressmen: 'diputados',
    parties:     'partidos',
    districts:   'distritos',
    blocks:      'bancadas',
  };

  const filterPeriod      = document.getElementById('filterPeriod');
  const filterEntity      = document.getElementById('filterEntity');
  const filterRanking     = document.getElementById('filterRanking');
  const searchName        = document.getElementById('searchName');
  const rankBody          = document.getElementById('rankBody');
  const resultsCount      = document.getElementById('resultsCount');
  const colValueHeader    = document.getElementById('colValueHeader');
  const rankingInfoDesc    = document.getElementById('rankingInfoDesc');
  const rankingInfoFormula = document.getElementById('rankingInfoFormula');

  function esc(str) {
    return String(str)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function barColor() {
    return '#00b2e3';
  }

  function getHelper(row, metric) {
    if (metric === 'att_pct')               return `${row.att_present} / ${row.att_total}`;
    if (metric === 'session_absence_pct')   return `${row.att_absent + row.att_license} / ${row.att_total}`;
    if (metric === 'session_license_pct')   return `${row.att_license} / ${row.att_total}`;
    if (metric === 'session_absent_pct')    return `${row.att_absent} / ${row.att_total}`;
    if (metric === 'voting_attendance_pct') return `${row.vote_present} / ${row.vote_total}`;
    if (metric === 'voting_absence_pct')    return `${row.vote_absent} / ${row.vote_total}`;
    if (metric === 'voting_in_favor_pct')   return `${row.vote_in_favor} / ${row.vote_present}`;
    if (metric === 'voting_against_pct')    return `${row.vote_against} / ${row.vote_present}`;
    if (metric === 'majority_pct')          return `${row.with_majority} / ${row.vote_present}`;
    if (metric === 'minority_pct')          return `${row.with_minority} / ${row.vote_present}`;
    return '';
  }

  function updateRankingInfo() {
    const entity     = filterEntity.value;
    const metric     = filterRanking.value;
    const rankings   = RANKINGS[entity];
    const rankingDef = rankings.find(r => r.value === metric) ?? rankings[0];
    rankingInfoDesc.textContent    = rankingDef.description;
    rankingInfoFormula.textContent = rankingDef.formula;
  }

  function syncRankingOptions() {
    const entity   = filterEntity.value;
    const current  = filterRanking.value;
    const rankings = RANKINGS[entity];
    filterRanking.innerHTML = rankings
      .map(r => `<option value="${r.value}"${r.value === current ? ' selected' : ''}>${esc(r.label)}</option>`)
      .join('');
    updateRankingInfo();
  }

  function render() {
    const period  = filterPeriod.value;
    const entity  = filterEntity.value;
    const metric  = filterRanking.value;
    const query   = searchName.value.toLowerCase().trim();

    const rankings   = RANKINGS[entity];
    const rankingDef = rankings.find(r => r.value === metric) ?? rankings[0];

    colValueHeader.textContent = rankingDef.label;

    // Sort and assign permanent ranks before filtering
    const sorted = (DATA[entity]?.[period] ?? []).slice();
    sorted.sort((a, b) => (b[metric] ?? 0) - (a[metric] ?? 0));
    const ranked = sorted.map((row, i) => ({ ...row, rank: i + 1 }));

    // Filter preserves original rank numbers
    const visible = query ? ranked.filter(r => r.name.toLowerCase().includes(query)) : ranked;

    resultsCount.textContent = `${ranked.length} ${ENTITY_LABEL[entity]}`;

    if (visible.length === 0) {
      rankBody.innerHTML = '<p class="no-data">Sin resultados.</p>';
      return;
    }

    const isCongressman = entity === 'congressmen';

    rankBody.innerHTML = visible.map((row) => {
      const value = row[metric] ?? 0;
      const color = barColor(metric, value);
      const imgClass = isCongressman ? 'row-photo' : 'row-logo';

      const imgHtml = `<img src="${esc(row.photo)}" alt="" class="${imgClass}" loading="lazy" onerror="this.style.visibility='hidden';">`;

      const nameCol = `${imgHtml}
        <span class="row-info">
          <span class="row-fullname">${esc(row.name)}</span>
          ${row.badge ? `<span class="row-badge">${esc(row.badge)}</span>` : ''}
        </span>`;

      const helper = getHelper(row, metric);
      const barWidth = Math.min(100, Math.max(0, value));

      return `<a href="${esc(row.path)}" class="rank-row">
        <span class="col-rank rank-num">${row.rank}</span>
        <span class="col-name">${nameCol}</span>
        <span class="col-value">
          <span class="bar-track"><span class="bar-fill" style="width:${barWidth}%;background:${color}"></span></span>
          <span class="bar-meta">
            <span class="bar-value" style="color:${color}">${value}${rankingDef.unit}</span>
            ${helper ? `<span class="bar-helper">${esc(helper)}</span>` : ''}
          </span>
        </span>
      </a>`;
    }).join('');
  }

  filterPeriod.addEventListener('change', render);
  filterEntity.addEventListener('change', () => { syncRankingOptions(); render(); });
  filterRanking.addEventListener('change', () => { updateRankingInfo(); render(); });
  searchName.addEventListener('input', render);

  syncRankingOptions();
  render();
</script>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .filters {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .filter-group label {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .filter-group input,
  .filter-group select {
    width: 100%;
    padding: 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    color: var(--text-main);
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .filter-group input:focus,
  .filter-group select:focus {
    border-color: var(--accent-color);
  }

  .ranking-info {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    padding: 0.85rem 1rem;
    margin-bottom: 1.5rem;
    border-radius: 10px;
    background: color-mix(in srgb, var(--accent-color) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-color) 30%, transparent);
  }

  .ranking-info-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: var(--accent-color);
  }

  .ranking-info-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .ranking-info-desc {
    font-size: 0.85rem;
    color: var(--text-main);
    line-height: 1.45;
    margin: 0;
  }

  .ranking-info-formula {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: 'SF Mono', 'Fira Code', monospace;
    margin: 0;
  }

  .results-count {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    padding-left: 0.25rem;
  }

  .filter-inline {
    margin-bottom: 1.25rem;
  }

  .filter-inline input {
    width: 100%;
    padding: 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    color: var(--text-main);
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .filter-inline input:focus {
    border-color: var(--accent-color);
  }

  /* Table container */
  .rank-table {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .rank-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 1rem;
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border-color);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  /* Column widths — header (scoped) */
  .col-rank  { width: 36px; flex-shrink: 0; text-align: center; }
  .col-name  { flex: 1; min-width: 0; }
  .col-value { width: 240px; flex-shrink: 0; display: flex; align-items: center; gap: 0.5rem; }

  /* Dynamic rows */
  :global(.rank-row) {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--border-color);
    color: inherit;
    text-decoration: none;
    transition: background var(--transition-fast);
  }
  :global(.rank-row:last-child) { border-bottom: none; }
  :global(.rank-row:hover)      { background: var(--bg-tertiary); }

  :global(.rank-row .col-rank)  { width: 36px; flex-shrink: 0; text-align: center; }
  :global(.rank-row .col-name)  { flex: 1; min-width: 0; display: flex; align-items: center; gap: 0.65rem; }
