---
import Layout from '../../layouts/Layout.astro';
import db from '../../lib/db.js';

// Get all sessions with their attendance summaries
const sessions = db.prepare(`
  SELECT 
    s.id, s.type, s.session_number, s.start_date,
    COUNT(a.congressman_id) as total,
    SUM(CASE WHEN a.status = 'present' THEN 1 ELSE 0 END) as presente,
    SUM(CASE WHEN a.status = 'ausente' THEN 1 ELSE 0 END) as ausente
  FROM sessions s
  LEFT JOIN attendance a ON s.id = a.session_id
  GROUP BY s.id
  ORDER BY s.start_date DESC
`).all();

const formatDate = (dateString) => {
  const options = { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
  return new Date(dateString).toLocaleDateString('es-GT', options);
};

const formatPct = (present, total) => {
  if (!total || total === 0) return '0%';
  return ((present / total) * 100).toFixed(0) + '%';
};
---

<Layout title="Historial de Sesiones">
  <div class="page-header">
    <h1>Sesiones Plenarias</h1>
    <p class="text-muted">Registro de sesiones y su nivel de asistencia general.</p>
  </div>

  <div class="sessions-list">
    {sessions.map(s => (
      <a href={`/sesiones/${s.id}`} class="session-card glass-panel">
        <div class="session-info">
          <div class="session-meta">
            <span class="badge" style="background: var(--bg-tertiary)">{s.type.toUpperCase()}</span>
            <span class="session-date">{formatDate(s.start_date)}</span>
          </div>
          <h3>Sesión No. {s.session_number}</h3>
        </div>
        
        <div class="session-stats">
          <div class="stat-text">
            <span>Asistencia:</span>
            <strong>{formatPct(s.presente, s.total)}</strong>
          </div>
          <div class="progress-bar-bg">
            <div class="progress-bar-fill" style={`width: ${formatPct(s.presente, s.total)}`}></div>
          </div>
        </div>
      </a>
    ))}
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .sessions-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .session-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    color: inherit;
  }

  .session-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .session-date {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .session-info h3 {
    margin: 0;
    font-size: 1.3rem;
  }

  .session-stats {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    width: 200px;
  }

  .stat-text {
    font-size: 0.9rem;
    display: flex;
    gap: 0.5rem;
  }

  .progress-bar-bg {
    width: 100%;
    height: 8px;
    background: var(--bg-tertiary);
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: var(--accent-color);
    border-radius: 4px;
  }

  .session-card:hover {
    border-color: var(--accent-color);
  }

  @media (max-width: 600px) {
    .session-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
    .session-stats {
      width: 100%;
      align-items: flex-start;
    }
  }
</style>
