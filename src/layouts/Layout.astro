---
import '../styles/global.css';
import {
	BLOCKS_PATH,
	CONGRESSMEN_PATH,
	DISTRICTS_PATH,
	PARTIES_PATH,
	RANKINGS_PATH,
	SESSIONS_PATH,
	VOTING_PATH
} from "../lib/paths.ts";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Analiza el comportamiento y las votaciones de los diputados en el Congreso." } = Astro.props;

const path = Astro.url.pathname;
function active(href: string) {
	return path === href || path.startsWith(href + '/') ? 'active' : '';
}
---

<!DOCTYPE html>
<html lang="es">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<meta name="generator" content={Astro.generator} />
	<meta name="description" content={description} />
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	<title>{title} | Guate No Olvida</title>
</head>
<body>
	<header class="navbar">
		<div class="nav-container">
			<!-- Logo -->
			<a href="/" class="nav-logo" aria-label="Guate No Olvida — inicio">
				<span class="nav-logo-flag" aria-hidden="true">🇬🇹</span>
				<div class="nav-logo-text">
					<span class="nav-logo-name">Guate <em>No Olvida</em></span>
					<span class="nav-logo-sub">Congreso · Guatemala</span>
				</div>
			</a>

			<!-- Desktop links -->
			<nav class="nav-links" id="navLinks" aria-label="Navegación principal">
				<a href={CONGRESSMEN_PATH} class={active(CONGRESSMEN_PATH)}>Diputados</a>
				<a href={DISTRICTS_PATH}   class={active(DISTRICTS_PATH)}>Distritos</a>
				<a href={BLOCKS_PATH}      class={active(BLOCKS_PATH)}>Bancadas</a>
				<a href={PARTIES_PATH}     class={active(PARTIES_PATH)}>Partidos</a>
				<a href={SESSIONS_PATH}    class={active(SESSIONS_PATH)}>Sesiones</a>
				<a href={VOTING_PATH}      class={active(VOTING_PATH)}>Votaciones</a>
				<a href={RANKINGS_PATH}    class={active(RANKINGS_PATH)}>Clasificaciones</a>
			</nav>

			<!-- Hamburger -->
			<button class="mobile-menu-btn" id="mobileMenuBtn"
				aria-label="Abrir menú" aria-expanded="false" aria-controls="navLinks">
				<svg class="icon-menu" xmlns="http://www.w3.org/2000/svg" width="22" height="22"
					viewBox="0 0 24 24" fill="none" stroke="currentColor"
					stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<line x1="3" y1="6"  x2="21" y2="6"/>
					<line x1="3" y1="12" x2="21" y2="12"/>
					<line x1="3" y1="18" x2="21" y2="18"/>
				</svg>
				<svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="22" height="22"
					viewBox="0 0 24 24" fill="none" stroke="currentColor"
					stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<line x1="18" y1="6" x2="6" y2="18"/>
					<line x1="6"  y1="6" x2="18" y2="18"/>
				</svg>
			</button>
		</div>
	</header>

	<main class="container">
		<slot />
	</main>

	<script>
		const btn   = document.getElementById('mobileMenuBtn') as HTMLButtonElement;
		const links = document.getElementById('navLinks') as HTMLElement;

		function openMenu() {
			links.classList.add('is-open');
			btn.setAttribute('aria-expanded', 'true');
			document.body.style.overflow = 'hidden';
		}

		function closeMenu() {
			links.classList.remove('is-open');
			btn.setAttribute('aria-expanded', 'false');
			document.body.style.overflow = '';
		}

		btn?.addEventListener('click', () => {
			links.classList.contains('is-open') ? closeMenu() : openMenu();
		});

		// Close when a nav link is tapped
		links?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

		// Close on Escape
		document.addEventListener('keydown', e => {
			if (e.key === 'Escape') closeMenu();
		});
	</script>
</body>
</html>

<style is:global>
	/* ── Navbar shell ─────────────────────────────────── */
	.navbar {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: #0f172a;
		border-bottom: 2px solid var(--accent-color);
	}

	.nav-container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 1.25rem;
		height: 60px;
	}

	/* ── Logo ─────────────────────────────────────────── */
	.nav-logo {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		text-decoration: none;
		flex-shrink: 0;
	}

	.nav-logo-flag {
		font-size: 1.35rem;
		line-height: 1;
	}

	.nav-logo-text {
		display: flex;
		flex-direction: column;
		gap: 0;
		line-height: 1;
	}

	.nav-logo-name {
		font-size: 1.05rem;
		font-weight: 800;
		color: #fff;
		letter-spacing: -0.02em;
		line-height: 1.15;
	}

	.nav-logo-name em {
		font-style: normal;
		color: var(--accent-color);
	}

	.nav-logo-sub {
		font-size: 0.58rem;
		font-weight: 500;
		color: rgba(255, 255, 255, 0.35);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-top: 0.15rem;
	}

	/* ── Hamburger button (mobile only) ───────────────── */
	.mobile-menu-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		background: none;
		border: none;
		color: rgba(255, 255, 255, 0.75);
		cursor: pointer;
		padding: 0.4rem;
		border-radius: 8px;
		transition: color var(--transition-fast), background var(--transition-fast);
		-webkit-tap-highlight-color: transparent;
	}

	.mobile-menu-btn:hover {
		color: #fff;
		background: rgba(255, 255, 255, 0.08);
	}

	.mobile-menu-btn .icon-close { display: none; }
	.mobile-menu-btn[aria-expanded="true"] .icon-menu  { display: none; }
	.mobile-menu-btn[aria-expanded="true"] .icon-close { display: block; }

	/* ── Nav links — mobile-first (overlay panel) ─────── */
	.nav-links {
		display: flex;
		flex-direction: column;
		position: fixed;
		top: 62px; /* navbar height + border */
		left: 0;
		right: 0;
		bottom: 0;
		background: #0f172a;
		padding: 1.5rem 1.25rem;
		gap: 0.25rem;
		overflow-y: auto;

		/* hidden by default on mobile */
		opacity: 0;
		pointer-events: none;
		transform: translateY(-8px);
		transition: opacity 0.18s ease, transform 0.18s ease;
	}

	.nav-links.is-open {
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0);
	}

	.nav-links a {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.85rem 1rem;
		border-radius: 10px;
		font-size: 1.05rem;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.65);
		text-decoration: none;
		border-left: 3px solid transparent;
		transition: color var(--transition-fast), background var(--transition-fast), border-color var(--transition-fast);
	}

	.nav-links a:hover {
		color: #fff;
		background: rgba(255, 255, 255, 0.06);
	}

	.nav-links a.active {
		color: var(--accent-color);
		background: rgba(0, 178, 227, 0.1);
		border-left-color: var(--accent-color);
	}

	/* ── Desktop overrides ────────────────────────────── */
	@media (min-width: 768px) {
		.nav-container {
			height: 64px;
			padding: 0 2rem;
		}

		.mobile-menu-btn {
			display: none;
		}

		.nav-links {
			/* reset overlay styles */
			position: static;
			flex-direction: row;
			background: none;
			padding: 0;
			gap: 0.15rem;
			overflow: visible;
			opacity: 1;
			pointer-events: auto;
			transform: none;
			transition: none;
			bottom: auto;
		}

		.nav-links a {
			padding: 0.4rem 0.65rem;
			font-size: 0.875rem;
			font-weight: 500;
			border-left: none;
			border-bottom: 2px solid transparent;
			border-radius: 6px;
			color: rgba(255, 255, 255, 0.6);
		}

		.nav-links a:hover {
			color: #fff;
			background: rgba(255, 255, 255, 0.07);
			border-bottom-color: rgba(255, 255, 255, 0.2);
		}

		.nav-links a.active {
			color: var(--accent-color);
			background: rgba(0, 178, 227, 0.1);
			border-left-color: transparent;
			border-bottom-color: var(--accent-color);
		}
	}
</style>
