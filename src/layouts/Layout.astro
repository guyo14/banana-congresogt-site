---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Analiza el comportamiento y las votaciones de los diputados en el Congreso." } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<meta name="generator" content={Astro.generator} />
	<meta name="description" content={description} />
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	<title>{title} | Guate No Olvida</title>
</head>
<body>
	<nav class="navbar">
		<div class="nav-container">
			<div class="nav-header">
				<a href="/" class="nav-logo">
					🇬🇹 Guate<span>No Olvida</span>
				</a>
				<button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Abrir menú">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="3" y1="12" x2="21" y2="12"></line>
						<line x1="3" y1="6" x2="21" y2="6"></line>
						<line x1="3" y1="18" x2="21" y2="18"></line>
					</svg>
				</button>
			</div>
			<div class="nav-links" id="navLinks">
				<a href="/congresistas">Diputados</a>
				<a href="/distritos">Distritos</a>
				<a href="/bancadas">Bancadas</a>
				<a href="/partidos">Partidos</a>
				<a href="/sesiones">Sesiones</a>
				<a href="/votaciones">Votaciones</a>
				<!-- In progress -->
				<!-- <a href="/ranking">Ranking</a> -->
				<!-- <a href="/compare">Comparar</a> -->
			</div>
		</div>
	</nav>

	<main class="container">
		<slot />
	</main>

	<script>
		const btn = document.getElementById('mobileMenuBtn');
		const links = document.getElementById('navLinks');
		if (btn && links) {
			btn.addEventListener('click', () => {
				links.classList.toggle('active');
			});
		}
	</script>
</body>
</html>
